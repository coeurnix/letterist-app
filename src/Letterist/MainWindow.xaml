                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TailCurvatureLabelText" Text="Curvature" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="TailCurvatureValueText" Grid.Column="1" Text="30%" FontSize="11" Foreground="#aaaaaa"/>
                                        </Grid>
                                        <Slider x:Name="TailCurvatureSlider"
                                                Minimum="-200" Maximum="200"
                                                Value="30"
                                                StepFrequency="5"
                                                ValueChanged="TailCurvatureSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Curve Center (for curved tails) -->
                                    <StackPanel x:Name="TailCurveCenterPanel" Spacing="4" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TailCurveCenterLabelText" Text="Curve Center" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="TailCurveCenterValueText" Grid.Column="1" Text="50%" FontSize="11" Foreground="#aaaaaa"/>
                                        </Grid>
                                        <Slider x:Name="TailCurveCenterSlider"
                                                Minimum="0" Maximum="100"
                                                Value="50"
                                                StepFrequency="2"
                                                ValueChanged="TailCurveCenterSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Inset (for pointer and curved tails) -->
                                    <StackPanel x:Name="TailInsetPanel" Spacing="4" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TailInsetLabelText" Text="Inset" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="TailInsetValueText" Grid.Column="1" Text="0" FontSize="11" Foreground="#aaaaaa"/>
                                        </Grid>
                                        <Slider x:Name="TailInsetSlider"
                                                Minimum="0" Maximum="64"
                                                Value="0"
                                                StepFrequency="1"
                                                ValueChanged="TailInsetSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Reset Tail Attachment -->
                                    <Button x:Name="ResetTailAttachmentButton"
                                            Content="Reset Attachment"
                                            Click="ResetTailAttachmentButton_Click"
                                            HorizontalAlignment="Stretch"
                                            Padding="8,6"
                                            Background="#3a3a3a"/>

                                    <!-- Add Tail Button -->
                                    <Button x:Name="AddTailButton"
                                            Content="+ Add Another Tail"
                                            Click="AddTailButton_Click"
                                            HorizontalAlignment="Stretch"
                                            Padding="8,6"
                                            Background="#3a3a3a"/>

                                    <!-- Balloon Links Section (merged from Links tab) -->
                                    <Border Height="1" Background="#2d2d2d" Margin="0,4,0,4"/>

                                    <TextBlock x:Name="TailLinksHeaderText"
                                               Text="BALLOON LINKS"
                                               Style="{StaticResource BalloonDetailSectionHeaderStyle}"/>

                                    <!-- Link Color -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="LinkColorLabelText" Text="Link Color" FontSize="11" Foreground="#888888"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border x:Name="LinkColorPreview"
                                                    Width="24" Height="24"
                                                    CornerRadius="4"
                                                    BorderBrush="#555555"
                                                    BorderThickness="1"
                                                    Background="#1E1E1E"/>
                                            <ComboBox x:Name="LinkColorComboBox"
                                                      SelectionChanged="LinkColorComboBox_SelectionChanged"
                                                      Width="120">
                                                <ComboBoxItem Content="Black" Tag="#000000"/>
                                                <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                                <ComboBoxItem Content="Dark Gray" Tag="#444444"/>
                                                <ComboBoxItem Content="Blue" Tag="#0066CC"/>
                                                <ComboBoxItem Content="Red" Tag="#CC0000"/>
                                                <ComboBoxItem Content="Green" Tag="#008800"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Border Width -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="LinkBorderWidthLabelText" Text="Border Width" FontSize="11" Foreground="#888888"/>
                                        <Slider x:Name="LinkWidthSlider"
                                                Minimum="1" Maximum="8"
                                                ValueChanged="LinkWidthSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Connector Width -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="ConnectorWidthLabelText" Text="Connector Width" FontSize="11" Foreground="#888888"/>
                                        <Slider x:Name="LinkConnectorWidthSlider"
                                                Minimum="8" Maximum="60"
                                                ValueChanged="LinkConnectorWidthSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Dash Style -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="DashStyleLabelText" Text="Dash Style" FontSize="11" Foreground="#888888"/>
                                        <ComboBox x:Name="LinkDashComboBox"
                                                  SelectionChanged="LinkDashComboBox_SelectionChanged"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Solid" Tag="Solid"/>
                                            <ComboBoxItem Content="Dash" Tag="Dash"/>
                                            <ComboBoxItem Content="Dot" Tag="Dot"/>
                                            <ComboBoxItem Content="Dash Dot" Tag="DashDot"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Link List -->
                                    <StackPanel Spacing="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="LinkedBalloonsLabelText" Text="Linked Balloons" FontSize="11" Foreground="#888888"/>
                                            <Button x:Name="ClearLinksButton"
                                                    Grid.Column="1"
                                                    Content="Clear"
                                                    Click="ClearLinksButton_Click"
                                                    Padding="8,4"
                                                    Background="#3a3a3a"/>
                                        </Grid>
                                        <TextBlock x:Name="LinkListEmptyText"
                                                   Text="No links on this page."
                                                   FontSize="11"
                                                   Foreground="#777777"/>
                                        <StackPanel x:Name="LinkListPanel" Spacing="6"/>
                                    </StackPanel>
                                    </StackPanel>
                            </StackPanel>
                            </ScrollViewer>

                            <!-- Guides Tab Content removed - now in left sidebar -->
                            <StackPanel Grid.Row="2" x:Name="PropGuidesTabScrollViewer" Visibility="Collapsed"/>
                            <StackPanel x:Name="GuidesPropertiesPanel" Visibility="Collapsed"/>

                            <!-- Templates Tab Content (moved to style strip, kept for code compat) -->
                            <ScrollViewer Grid.Row="2" x:Name="PropTemplatesTabScrollViewer"
                                          VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" Visibility="Collapsed">
                            <StackPanel x:Name="PropTemplatesTabContent" Padding="12,8" Spacing="12">

                                        <!-- Last Used Template -->
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="LastUsedTemplateLabelText" Text="Last Used" FontSize="11" Foreground="#888888"/>
                                            <Border x:Name="LastUsedTemplateBorder" Background="#2a2a2a" CornerRadius="6" Padding="8" Visibility="Collapsed">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="LastUsedTemplatePreview" Grid.Column="0"
                                                            Width="48" Height="40" CornerRadius="4" BorderThickness="1"
                                                            BorderBrush="#444444" Background="#1e1e1e"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock x:Name="LastUsedTemplateNameText" FontSize="12" Foreground="#dddddd" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock x:Name="LastUsedTemplateCategoryText" FontSize="10" Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <TextBlock x:Name="NoLastUsedTemplateText" Text="No template used yet."
                                                       FontSize="11" Foreground="#666666"/>
                                        </StackPanel>

                                        <Border Height="1" Background="#2d2d2d" Margin="0,2,0,2"/>

                                        <!-- Template Gallery -->
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="BalloonTemplatesLabelText" Text="Balloon Templates" FontSize="11" Foreground="#888888"/>
                                            <ItemsControl x:Name="BalloonTemplateGallery">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Spacing="4"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </StackPanel>

                                        <Border Height="1" Background="#2d2d2d" Margin="0,2,0,2"/>

                                        <!-- Template Actions -->
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="TemplateActionsLabelText" Text="Actions" FontSize="11" Foreground="#888888"/>
                                            <ComboBox x:Name="BalloonTemplatePresetComboBox"
                                                      SelectionChanged="BalloonTemplatePresetComboBox_SelectionChanged"
                                                      HorizontalAlignment="Stretch"
                                                      PlaceholderText="Select template..."/>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="ApplyBalloonTemplateButton"
                                                        Grid.Column="0"
                                                        Content="Apply"
                                                        Click="ApplyBalloonTemplate_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                                <Button x:Name="UseBalloonTemplateForNewButton"
                                                        Grid.Column="1"
                                                        Content="Use For New"
                                                        Click="UseBalloonTemplateForNewButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="SaveBalloonTemplateButton"
                                                        Grid.Column="0"
                                                        Content="Save From Selection"
                                                        Click="SaveBalloonTemplateButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                                <Button x:Name="UpdateBalloonTemplateButton"
                                                        Grid.Column="1"
                                                        Content="Update From Selection"
                                                        Click="UpdateBalloonTemplateButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="RenameBalloonTemplateButton"
                                                        Grid.Column="0"
                                                        Content="Rename"
                                                        Click="RenameBalloonTemplateButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                                <Button x:Name="DeleteBalloonTemplateButton"
                                                        Grid.Column="1"
                                                        Content="Delete"
                                                        Click="DeleteBalloonTemplateButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ToggleButton x:Name="BalloonTemplateFavoriteToggleButton"
                                                              Grid.Column="0"
                                                              Content="Favorite"
                                                              Click="BalloonTemplateFavoriteToggleButton_Click"
                                                              Padding="8,4"
                                                              Background="#3a3a3a"/>
                                                <ComboBox x:Name="BalloonTemplateHotkeyComboBox"
                                                          Grid.Column="1"
                                                          SelectionChanged="BalloonTemplateHotkeyComboBox_SelectionChanged"
                                                          PlaceholderText="Hotkey"
                                                          HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="No Hotkey" Tag="none"/>
                                                    <ComboBoxItem Content="Alt+1" Tag="1"/>
                                                    <ComboBoxItem Content="Alt+2" Tag="2"/>
                                                    <ComboBoxItem Content="Alt+3" Tag="3"/>
                                                    <ComboBoxItem Content="Alt+4" Tag="4"/>
                                                    <ComboBoxItem Content="Alt+5" Tag="5"/>
                                                    <ComboBoxItem Content="Alt+6" Tag="6"/>
                                                    <ComboBoxItem Content="Alt+7" Tag="7"/>
                                                    <ComboBoxItem Content="Alt+8" Tag="8"/>
                                                    <ComboBoxItem Content="Alt+9" Tag="9"/>
                                                </ComboBox>
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ToggleButton x:Name="BalloonTemplateEyedropperToggleButton"
                                                              Grid.ColumnSpan="2"
                                                              Content="Style Eyedropper"
                                                              Click="BalloonTemplateEyedropperToggleButton_Click"
                                                              Padding="8,4"
                                                              Background="#3a3a3a"
                                                              ToolTipService.ToolTip="Sample a balloon style from canvas and apply/save as template"/>
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="ImportBalloonTemplatePackButton"
                                                        Grid.Column="0"
                                                        Content="Import Pack"
                                                        Click="ImportBalloonTemplatePackButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                                <Button x:Name="ExportBalloonTemplatePackButton"
                                                        Grid.Column="1"
                                                        Content="Export Pack"
                                                        Click="ExportBalloonTemplatePackButton_Click"
                                                        Padding="8,4"
                                                        Background="#3a3a3a"/>
                                            </Grid>
                                            <TextBlock x:Name="QuickApplyHintText" Text="Quick apply: Alt+1..9"
                                                       FontSize="10"
                                                       Foreground="#777777"/>
                                        </StackPanel>
                            </StackPanel>
                            </ScrollViewer>

                            <!-- Style Strip (bottom) -->
                            <Border Grid.Row="3" Background="#222222" Padding="8,6" BorderBrush="#1a1a1a" BorderThickness="0,1,0,0">
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="StyleStripComboBox"
                                              SelectionChanged="StyleStripComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="Style..."
                                              MinWidth="220"
                                              Height="30" FontSize="11"/>
                                    <Button x:Name="StyleStripEditButton"
                                            Grid.Column="1"
                                            Content="Edit"
                                            Click="StyleStripEdit_Click"
                                            Padding="6,4"
                                            Height="30"
                                            Background="#3a3a3a"
                                            FontSize="11"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Panel Zone Properties (shown when a panel is selected) -->
                        <Grid x:Name="PanelZonePropertiesPanel"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#252525" Padding="12,8">
                                <TextBlock x:Name="PanelDetailHeaderText" Text="Panel Detail" FontWeight="SemiBold" FontSize="13" Foreground="#ffffff"/>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Padding="12,8" Spacing="12">
                                <!-- Panel Name -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="PanelNameLabelText" Text="Name" FontSize="11" Foreground="#888888"/>
                                    <TextBox x:Name="PanelNameTextBox"
                                             PlaceholderText="Panel name"
                                             LostFocus="PanelNameTextBox_LostFocus"
                                             KeyDown="PanelNameTextBox_KeyDown"/>
                                </StackPanel>

                                <!-- Panel Shape -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="PanelShapeLabelText" Text="Shape" FontSize="11" Foreground="#888888"/>
                                    <ComboBox x:Name="PanelShapeComboBox"
                                              SelectionChanged="PanelShapeComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Rectangle" Tag="Rectangle"/>
                                        <ComboBoxItem Content="Rounded Rectangle" Tag="RoundedRect"/>
                                        <ComboBoxItem Content="Ellipse" Tag="Ellipse"/>
                                        <ComboBoxItem Content="Custom" Tag="Custom"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Corner Radius (for rounded rect) -->
                                <StackPanel x:Name="PanelCornerRadiusPanel" Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="PanelCornerRadiusLabelText" Text="Corner Radius" FontSize="11" Foreground="#888888"/>
                                    <Slider x:Name="PanelCornerRadiusSlider"
                                            Minimum="0" Maximum="100"
                                            ValueChanged="PanelCornerRadiusSlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Border -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="PanelBorderLabelText" Text="Border" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="PanelBorderColorPreview"
                                                Width="24" Height="24"
                                                CornerRadius="4"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                Background="#1E1E1E"/>
                                        <ComboBox x:Name="PanelBorderColorComboBox"
                                                  Grid.Column="1"
                                                  SelectionChanged="PanelBorderColorComboBox_SelectionChanged"
                                                  HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Black" Tag="#1E1E1E"/>
                                            <ComboBoxItem Content="Dark Gray" Tag="#444444"/>
                                            <ComboBoxItem Content="Gray" Tag="#888888"/>
                                            <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Name="PanelBorderWidthLabelText" Text="Width" FontSize="10" Foreground="#666666"/>
                                            <Slider x:Name="PanelBorderWidthSlider"
                                                    Minimum="0" Maximum="10"
                                                    ValueChanged="PanelBorderWidthSlider_ValueChanged"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock x:Name="PanelBorderStyleDetailLabelText" Text="Style" FontSize="10" Foreground="#666666"/>
                                            <ComboBox x:Name="PanelBorderStyleComboBox"
                                                      SelectionChanged="PanelBorderStyleComboBox_SelectionChanged"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Solid" Tag="Solid"/>
                                                <ComboBoxItem Content="Dashed" Tag="Dashed"/>
                                                <ComboBoxItem Content="Dotted" Tag="Dotted"/>
                                                <ComboBoxItem Content="Dash-Dot" Tag="DashDot"/>
                                                <ComboBoxItem Content="None" Tag="None"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- Position -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="PanelPositionLabelText" Text="Position" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="PanelXBox" Header="X" SpinButtonPlacementMode="Hidden"
                                                   ValueChanged="PanelPositionBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelYBox" Grid.Column="1" Header="Y" SpinButtonPlacementMode="Hidden"
                                                   ValueChanged="PanelPositionBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Size -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="PanelSizeLabelText" Text="Size" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="PanelWidthBox" Header="Width" SpinButtonPlacementMode="Hidden" Minimum="10"
                                                   ValueChanged="PanelSizeBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelHeightBox" Grid.Column="1" Header="Height" SpinButtonPlacementMode="Hidden" Minimum="10"
                                                   ValueChanged="PanelSizeBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Aspect Ratio -->
                                <StackPanel Spacing="4">
                                    <ToggleSwitch x:Name="PanelAspectRatioLockToggle"
                                                  Header="Lock Aspect Ratio"
                                                  OnContent="Yes" OffContent="No"
                                                  Toggled="PanelAspectRatioLockToggle_Toggled"/>
                                </StackPanel>

                                <!-- Size Preset -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="PanelSizePresetLabelText" Text="Size Preset" FontSize="11" Foreground="#888888"/>
                                    <ComboBox x:Name="PanelSizePresetComboBox"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="PanelSizePresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Custom" Tag="custom"/>
                                        <ComboBoxItem Content="Square (1:1)" Tag="1:1"/>
                                        <ComboBoxItem Content="16:9" Tag="16:9"/>
                                        <ComboBoxItem Content="4:3" Tag="4:3"/>
                                        <ComboBoxItem Content="3:4" Tag="3:4"/>
                                        <ComboBoxItem Content="Golden Ratio (1.618:1)" Tag="1.618:1"/>
                                        <ComboBoxItem Content="Custom ratio..." Tag="custom-ratio"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Safe Margin -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="PanelSafeMarginLabelText" Text="Safe Margin" FontSize="11" Foreground="#888888"/>
                                    <NumberBox x:Name="PanelSafeMarginBox" Header="Inset" SpinButtonPlacementMode="Hidden" Minimum="0"
                                               ValueChanged="PanelSafeMarginBox_ValueChanged"/>
                                </StackPanel>

                                <!-- Gutter Overrides -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="GutterOverridesLabelText" Text="Gutter Overrides" FontSize="11" Foreground="#888888"/>
                                    <ToggleSwitch x:Name="PanelCustomGutterToggle"
                                                  Header="Custom per-edge gutters"
                                                  OnContent="On" OffContent="Off"
                                                  Toggled="PanelCustomGutterToggle_Toggled"/>
                                    <Grid x:Name="PanelGutterOverrideGrid" ColumnSpacing="8" RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="PanelGutterLeftBox" Header="Left" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelGutterOverrideBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelGutterRightBox" Grid.Column="1" Header="Right" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelGutterOverrideBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelGutterTopBox" Grid.Row="1" Header="Top" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelGutterOverrideBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelGutterBottomBox" Grid.Row="1" Grid.Column="1" Header="Bottom" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelGutterOverrideBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Bleed -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="PanelBleedLabelText" Text="Bleed" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnSpacing="8" RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <NumberBox x:Name="PanelBleedLeftBox" Header="Left" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelBleedBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelBleedRightBox" Grid.Column="1" Header="Right" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelBleedBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelBleedTopBox" Grid.Row="1" Header="Top" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelBleedBox_ValueChanged"/>
                                        <NumberBox x:Name="PanelBleedBottomBox" Grid.Row="1" Grid.Column="1" Header="Bottom" SpinButtonPlacementMode="Hidden" Minimum="0"
                                                   ValueChanged="PanelBleedBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Reading Order -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="ReadingOrderLabelText" Text="Reading Order" FontSize="11" Foreground="#888888"/>
                                    <NumberBox x:Name="PanelOrderBox" Minimum="1" SpinButtonPlacementMode="Hidden"
                                               ValueChanged="PanelOrderBox_ValueChanged"/>
                                </StackPanel>

                                <!-- Panel Image -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="PanelImageLabelText" Text="Panel Image" FontSize="11" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="LoadPanelImageButton"
                                                Content="Load/Replace"
                                                Click="LoadPanelImage_Click"/>
                                        <Button x:Name="ClearPanelImageButton"
                                                Content="Clear"
                                                Click="ClearPanelImage_Click"/>
                                    </StackPanel>
                                    <TextBlock x:Name="PanelImageStatusText"
                                               Text="No image loaded"
                                               FontSize="11"
                                               Foreground="#777777"/>

                                    <!-- Image Fit Mode -->
                                    <StackPanel x:Name="PanelImageOptionsPanel" Visibility="Collapsed" Spacing="8" Margin="0,8,0,0">
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="PanelImageFitModeLabelText" Text="Fit Mode" FontSize="11" Foreground="#888888"/>
                                            <ComboBox x:Name="PanelImageFitModeComboBox"
