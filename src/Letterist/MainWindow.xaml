                                                    </StackPanel>
                                                    <StackPanel Spacing="3">
                                                        <TextBlock x:Name="FloatingImageGlowIntensityLabelText" Text="Intensity" FontSize="10" Foreground="#888888"/>
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <Slider x:Name="FloatingImageGlowIntensitySlider"
                                                                    Minimum="0" Maximum="100"
                                                                    StepFrequency="1"
                                                                    ValueChanged="FloatingImageGlowSlider_ValueChanged"/>
                                                            <TextBlock x:Name="FloatingImageGlowIntensityValueText"
                                                                       Grid.Column="1"
                                                                       Text="0%"
                                                                       FontSize="11"
                                                                       Foreground="#aaaaaa"
                                                                       MinWidth="44"
                                                                       VerticalAlignment="Center"
                                                                       TextAlignment="Right"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Detailed Information -->
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="OwnershipLabelText" Text="Ownership" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="FloatingImageLayerText"
                                                       Text="Layer: (none)"
                                                       FontSize="11"
                                                       Foreground="#777777"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="ImageFileLabelText" Text="Image File" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="FloatingImagePathText"
                                                       Text="(no file)"
                                                       FontSize="11"
                                                       Foreground="#777777"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="FloatingImageSourceLabelText" Text="Image Source" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="FloatingImageSourceText"
                                                       Text="(none)"
                                                       FontSize="11"
                                                       Foreground="#777777"
                                                       TextWrapping="WrapWholeWords"/>
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="FloatingImageMediaInfoLabelText" Text="Info" FontSize="11" Foreground="#888888"/>
                                            <TextBlock x:Name="FloatingImageMediaInfoText"
                                                       Text="-"
                                                       FontSize="11"
                                                       Foreground="#777777"
                                                       TextWrapping="WrapWholeWords"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                    <primitives:Thumb x:Name="RightSidebarHorizontalSplitter" Grid.Row="1"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="#1a1a1a"
                                      DragDelta="SidebarSplitter_DragDelta"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="#252525"
                Padding="12,6"
                BorderBrush="#1a1a1a"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Document Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               FontSize="12"
                               Foreground="#aaaaaa"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActiveTranslationIndicatorText"
                               Text=""
                               FontSize="12"
                               Foreground="#f4d35e"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Automation Status -->
                <TextBlock x:Name="AutomationStatus"
                           Grid.Column="1"
                           Text=""
                           FontSize="11"
                           Foreground="#4a9eff"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>


