                                                <ComboBoxItem Content="Fit (show all)" Tag="Fit"/>
                                                <ComboBoxItem Content="Stretch (distort)" Tag="Stretch"/>
                                                <ComboBoxItem Content="Original (1:1)" Tag="Original"/>
