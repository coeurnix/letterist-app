                                            <NumberBox x:Name="BalloonTextPathEndXBox"
                                                       Header="End X"
                                                       SmallChange="1"
                                                       SpinButtonPlacementMode="Hidden"
                                                       ValueChanged="BalloonTextPathNumberBox_ValueChanged"
                                                       KeyDown="NumberBox_KeyDown"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <NumberBox x:Name="BalloonTextPathStartYBox"
                                                       Header="Start Y"
                                                       SmallChange="1"
                                                       SpinButtonPlacementMode="Hidden"
