<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Letterist.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    Title="Letterist">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          KeyDown="RootGrid_KeyDown"
          ProcessKeyboardAccelerators="RootGrid_ProcessKeyboardAccelerators">
        <Grid.Resources>
            <Style x:Key="PropertiesExpanderStyle" TargetType="Expander">
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="HeaderTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <Border Background="#252525"
                                    Padding="6,3"
                                    HorizontalAlignment="Stretch">
                                <TextBlock Text="{Binding}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#e5e5e5"/>
                            </Border>
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="BalloonDetailSectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#666666"/>
            </Style>
            <Style x:Key="BalloonDetailCardLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#888888"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <DataTemplate x:Key="PanelTemplateItemTemplate">
                <Grid Padding="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="72"
                            Height="96"
                            Background="#1b1b1b"
                            BorderBrush="#333333"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#ffffff"/>
                            <FontIcon Glyph="&#xE73E;"
                                      FontSize="12"
                                      Foreground="#4CAF50"
                                      Visibility="{Binding MatchIconVisibility}"
                                      ToolTipService.ToolTip="Matches current page size"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}"
                                   FontSize="10"
                                   Foreground="#bbbbbb"
                                   TextWrapping="Wrap"
                                   MaxLines="2"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding SizeLabel}" FontSize="10" Foreground="#888888"/>
                            <TextBlock Text="{Binding CategoryLabel}" FontSize="10" Foreground="#888888"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TagsLabel}" FontSize="10" Foreground="#666666" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar with Menu and Toolbar -->
        <Border Grid.Row="0"
                Background="#1a1a1a"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Menu Bar -->
                <MenuBar x:Name="MainMenuBar" Grid.Column="0" VerticalAlignment="Center">
                    <MenuBarItem x:Name="MenuFileItem" Title="File">
                        <MenuFlyoutItem x:Name="MenuFileNew" Text="New Document" Click="NewDocument_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="N"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuFileOpen" Text="Open..." Click="OpenDocument_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="O"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSubItem x:Name="RecentDocumentsMenu" Text="Open Recent"/>
                        <MenuFlyoutItem x:Name="MenuFileSave" Text="Save" Click="SaveDocument_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="S"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuFileSaveAs" Text="Save As..." Click="SaveAsDocument_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="S"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuFileExport" Text="Export..." Click="ExportDocument_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="E"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuFileDocSettings" Text="Document Settings..." Click="DocumentSettings_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuFileTranslate"
                                        Text="Translate..."
                                        Click="ShowTranslationWindow_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="T"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuFilePreferences"
                                        Text="Preferences..."
                                        Click="Preferences_Click"
                                        KeyboardAcceleratorTextOverride="Ctrl+,"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutSubItem x:Name="MenuFileStyleLibrary" Text="Style Library">
                            <MenuFlyoutItem x:Name="MenuFileStyleImport" Text="Import..." Click="ImportStyleLibrary_Click"/>
                            <MenuFlyoutItem x:Name="MenuFileStyleExport" Text="Export..." Click="ExportStyleLibrary_Click"/>
                        </MenuFlyoutSubItem>
                    </MenuBarItem>
                    <MenuBarItem x:Name="MenuEditItem" Title="Edit">
                        <MenuFlyoutItem x:Name="MenuEditUndo" Text="Undo" Click="Undo_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Z"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditRedo" Text="Redo" Click="Redo_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Y"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuEditCut" Text="Cut" Click="CutBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="X"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditCopy" Text="Copy" Click="CopyBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="C"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditPaste" Text="Paste" Click="PasteBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="V"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditCopyStyle" Text="Copy Style" Click="CopyStyle_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Menu" Key="C"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditPasteStyle" Text="Paste Style" Click="PasteStyle_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Menu" Key="V"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditDuplicate" Text="Duplicate" Click="DuplicateBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="D"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditSelectAll" Text="Select All (Layer)" Click="SelectAllBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="A"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuEditFind" Text="Find..." Click="FindText_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="F"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuEditReplace" Text="Replace..." Click="ReplaceText_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="H"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutSubItem x:Name="MenuEditAlign" Text="Align">
                            <MenuFlyoutItem x:Name="MenuAlignLeft" Text="Left" Click="AlignLeft_Click"/>
                            <MenuFlyoutItem x:Name="MenuAlignCenter" Text="Center" Click="AlignCenter_Click"/>
                            <MenuFlyoutItem x:Name="MenuAlignRight" Text="Right" Click="AlignRight_Click"/>
                            <MenuFlyoutItem x:Name="MenuAlignTop" Text="Top" Click="AlignTop_Click"/>
                            <MenuFlyoutItem x:Name="MenuAlignMiddle" Text="Middle" Click="AlignMiddle_Click"/>
                            <MenuFlyoutItem x:Name="MenuAlignBottom" Text="Bottom" Click="AlignBottom_Click"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem x:Name="MenuEditDistribute" Text="Distribute">
                            <MenuFlyoutItem x:Name="MenuDistributeH" Text="Horizontally" Click="DistributeHorizontally_Click"/>
                            <MenuFlyoutItem x:Name="MenuDistributeV" Text="Vertically" Click="DistributeVertically_Click"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuEditDelete" Text="Delete" Click="Delete_Click" KeyboardAcceleratorTextOverride="Delete">
                        </MenuFlyoutItem>
                    </MenuBarItem>
                    <MenuBarItem x:Name="MenuObjectsItem" Title="Objects">
                        <MenuFlyoutItem x:Name="MenuObjectsAddBalloon" Text="Add Balloon" Click="AddBalloonMenu_Click"
                                        KeyboardAcceleratorTextOverride="B"/>
                        <MenuFlyoutItem x:Name="MenuObjectsToggleTail" Text="Toggle Tail" Click="ToggleTail_Click"
                                        KeyboardAcceleratorTextOverride="T"/>
                        <MenuFlyoutItem x:Name="MenuObjectsLinkBalloons" Text="Link Balloons (Ctrl+L)" Click="LinkBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="L"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuObjectsUnlinkBalloons" Text="Unlink Balloons (Ctrl+Shift+L)" Click="UnlinkBalloons_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="L"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuObjectsGroup" Text="Group Objects (Ctrl+G)" Click="GroupObjects_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="G"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuObjectsUngroup" Text="Ungroup Objects (Ctrl+Shift+G)" Click="UngroupObjects_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="G"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuFileImportDecoration"
                                        Text="Import Decoration..."
                                        Click="ImportFloatingImage_Click"
                                        KeyboardAcceleratorTextOverride="I"/>
                        <MenuFlyoutItem x:Name="MenuObjectsAddImageFromUrl" Text="Add Image from URL..." Click="AddImageFromUrl_Click"/>
                        <MenuFlyoutItem x:Name="MenuFilePasteImage" Text="Paste Image" Click="PasteImage_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="V"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuFileOpenImage" Text="Open Image..." Click="OpenImage_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="O"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuFileClearBackground" Text="Clear Background Image" Click="ClearBackgroundImage_Click"/>
                        <MenuFlyoutItem x:Name="MenuFileBatchImport" Text="Batch Import Images..." Click="BatchImportImages_Click"/>
                    </MenuBarItem>
                    <MenuBarItem x:Name="MenuViewItem" Title="View">
                        <MenuFlyoutItem x:Name="MenuViewZoomFit" Text="Zoom to Fit" Click="ZoomToFit_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Number0"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuViewZoomSelection" Text="Zoom to Selection" Click="ZoomToSelection_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Number1"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuViewZoom100" Text="Zoom 100%" Click="Zoom100_Click"/>
                        <MenuFlyoutItem x:Name="MenuViewZoomIn" Text="Zoom In" Click="ZoomIn_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Add"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuViewZoomOut" Text="Zoom Out" Click="ZoomOut_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="Subtract"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Name="ShowGridMenuItem"
                                              Text="Show Grid"
                                              Click="ShowGridMenuItem_Click">
                            <ToggleMenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="G"/>
                            </ToggleMenuFlyoutItem.KeyboardAccelerators>
                        </ToggleMenuFlyoutItem>
                        <ToggleMenuFlyoutItem x:Name="SnapToGridMenuItem"
                                              Text="Snap to Grid"
                                              Click="SnapToGridMenuItem_Click">
                            <ToggleMenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="G"/>
                            </ToggleMenuFlyoutItem.KeyboardAccelerators>
                        </ToggleMenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Name="SnapToGuidesMenuItem"
                                              Text="Snap to Guides"
                                              Click="SnapToGuidesMenuItem_Click"/>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Name="TypographyDiagnosticsMenuItem"
                                              Text="Show Typography Diagnostics"
                                              Click="TypographyDiagnostics_Click"/>
                    </MenuBarItem>
                    <MenuBarItem x:Name="MenuHelpItem" Title="Help">
                        <MenuFlyoutItem x:Name="MenuHelpQuickstart" Text="Quickstart..." Click="HelpQuickstart_Click"/>
                        <MenuFlyoutItem x:Name="MenuHelpContents" Text="Contents..." Click="HelpContents_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuHelpAbout" Text="About..." Click="AboutMenu_Click"/>
                    </MenuBarItem>
                    <MenuBarItem x:Name="MenuLayerItem" Title="Page">
                        <MenuFlyoutItem x:Name="MenuPageAdd" Text="Add Page" Click="AddPage_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Menu" Key="N"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuPageMoveUp" Text="Move Page Up" Click="MovePageUp_Click"/>
                        <MenuFlyoutItem x:Name="MenuPageMoveDown" Text="Move Page Down" Click="MovePageDown_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuLayerNew" Text="New Layer" Click="AddLayer_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Shift" Key="N"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuLayerMoveUp" Text="Move Layer Up" Click="MoveLayerUp_Click"/>
                        <MenuFlyoutItem x:Name="MenuLayerMoveDown" Text="Move Layer Down" Click="MoveLayerDown_Click"/>
                        <MenuFlyoutSeparator/>
                        <ToggleMenuFlyoutItem x:Name="MenuPanelDesignMode"
                                              Text="Panel Layout"
                                              Click="PanelDesignModeButton_Click"
                                              KeyboardAcceleratorTextOverride="P">
                        </ToggleMenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuPanelAdd" Text="Add Panel" Click="AddPanel_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuPanelTemplates" Text="Panel Templates..." Click="ShowTemplatesWindow_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuGuidesAddHorizontal" Text="Add Horizontal Guide" Click="AddHorizontalGuide_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Menu" Key="H"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuGuidesAddVertical" Text="Add Vertical Guide" Click="AddVerticalGuide_Click">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control,Menu" Key="V"/>
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>
                    </MenuBarItem>
                </MenuBar>

                <!-- Toolbar (inline with menu bar) -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Hidden"
                              ZoomMode="Disabled"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <!-- Primary tools -->
                        <Border Background="#243448"
                                BorderBrush="#4f73a8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="2,1"
                                Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <ToggleButton x:Name="SelectToolButton"
                                              ToolTipService.ToolTip="Select (V)"
                                              IsChecked="True"
                                              Click="SelectTool_Click"
                                              Padding="8,4"
                                              MinWidth="34"
                                              CornerRadius="4">
                                    <FontIcon Glyph="&#xEF20;" FontSize="13"/>
                                </ToggleButton>
                                <ToggleButton x:Name="CreateBalloonButton"
                                              ToolTipService.ToolTip="Create Balloon (B)"
                                              Click="CreateBalloonTool_Click"
                                              Padding="8,4"
                                              MinWidth="34"
                                              CornerRadius="4">
                                    <FontIcon Glyph="&#xE8F2;" FontSize="13"/>
                                </ToggleButton>
                            </StackPanel>
                        </Border>

                        <!-- Tail tool -->
                        <Border Background="#262626"
                                BorderBrush="#3d3d3d"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="1"
                                Margin="0,0,6,0">
                            <Button x:Name="ToggleTailButton"
                                    ToolTipService.ToolTip="Toggle Tail (T)"
                                    Click="ToggleTail_Click"
                                    Padding="7,4"
                                    MinWidth="32"
                                    CornerRadius="4">
                                <PathIcon Width="13" Height="13"
                                          Data="M2,2 H14 V9 H9.5 L5,13 V9 H2 Z"/>
                            </Button>
                        </Border>

                        <Border Width="1" Height="20" Background="#444444" Margin="3,0"/>

                        <!-- File -->
                        <Button x:Name="SaveToolbarButton"
                                Click="SaveDocument_Click"
                                ToolTipService.ToolTip="Save (Ctrl+S)"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE74E;" FontSize="13"/>
                        </Button>
                        <Button x:Name="ExportToolbarButton"
                                Click="ExportDocument_Click"
                                ToolTipService.ToolTip="Export (Ctrl+Shift+E)"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xEDE1;" FontSize="13"/>
                        </Button>

                        <Border Width="1" Height="20" Background="#444444" Margin="3,0"/>

                        <!-- History -->
                        <Button x:Name="UndoButton"
                                ToolTipService.ToolTip="Undo (Ctrl+Z)"
                                Click="Undo_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE7A7;" FontSize="13"/>
                        </Button>
                        <Button x:Name="RedoButton"
                                ToolTipService.ToolTip="Redo (Ctrl+Y)"
                                Click="Redo_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE7A6;" FontSize="13"/>
                        </Button>

                        <Border Width="1" Height="20" Background="#444444" Margin="3,0"/>

                        <!-- Clipboard/Edit -->
                        <Button x:Name="CutButton"
                                ToolTipService.ToolTip="Cut (Ctrl+X)"
                                Click="Cut_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE8C6;" FontSize="13"/>
                        </Button>
                        <Button x:Name="CopyButton"
                                ToolTipService.ToolTip="Copy (Ctrl+C)"
                                Click="Copy_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13"/>
                        </Button>
                        <Button x:Name="PasteButton"
                                ToolTipService.ToolTip="Paste (Ctrl+V)"
                                Click="Paste_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE77F;" FontSize="13"/>
                        </Button>
                        <Button x:Name="DeleteToolbarButton"
                                ToolTipService.ToolTip="Delete (Delete)"
                                Click="ToolbarDelete_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE74D;" FontSize="13"/>
                        </Button>

                        <Border Width="1" Height="20" Background="#444444" Margin="3,0"/>

                        <!-- View -->
                        <Button x:Name="ZoomOutToolbarButton"
                                ToolTipService.ToolTip="Zoom Out (Ctrl+-)"
                                Click="ZoomOut_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE71F;" FontSize="13"/>
                        </Button>
                        <Border Background="#2c2c2c"
                                BorderBrush="#3d3d3d"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="0"
                                MinWidth="64"
                                VerticalAlignment="Center">
                            <TextBox x:Name="ToolbarZoomBox"
                                     Text="100%"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Loaded="ToolbarZoomBox_Loaded"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontSize="11"
                                     Padding="8,2"
                                     MinHeight="0"
                                     KeyDown="ToolbarZoomBox_KeyDown"
                                     LostFocus="ToolbarZoomBox_LostFocus"/>
                        </Border>
                        <Button x:Name="ZoomInToolbarButton"
                                ToolTipService.ToolTip="Zoom In (Ctrl++)"
                                Click="ZoomIn_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE8A3;" FontSize="13"/>
                        </Button>
                        <Button x:Name="ZoomFitToolbarButton"
                                ToolTipService.ToolTip="Zoom to Fit (Ctrl+0)"
                                Click="ZoomToFit_Click"
                                Padding="6,4"
                                CornerRadius="4">
                            <FontIcon Glyph="&#xE9A6;" FontSize="13"/>
                        </Button>

                        <Border Width="1" Height="20" Background="#444444" Margin="3,0"/>

                        <!-- Global -->
                        <ToggleButton x:Name="SnapToolbarToggle"
                                      Click="ToolbarSnapToggle_Click"
                                      ToolTipService.ToolTip="Snap to Guides"
                                      Padding="6,4"
                                      CornerRadius="4">
                            <FontIcon Glyph="&#xE8FC;" FontSize="13"/>
                        </ToggleButton>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Main Content Area with Canvas and Panels -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftSidebarColumn" Width="220" MinWidth="180"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition x:Name="RightSidebarColumn" Width="260" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar with Pages/Layers/Panels -->
            <Border x:Name="LeftSidebarBorder" Grid.Column="0" Background="#2b2b2b"
                    BorderBrush="#1a1a1a" BorderThickness="0,0,1,0">
                <Grid x:Name="RightSidebarGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left Sidebar Tab Buttons -->
                    <Border x:Name="LeftSidebarTabsHeaderBorder"
                            Grid.Row="0"
                            Background="#252525"
                            Padding="4,4"
                            SizeChanged="LeftSidebarTabsHeaderBorder_SizeChanged">
                        <StackPanel x:Name="LeftSidebarTabsHeaderStackPanel" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                            <ToggleButton x:Name="LeftSidebarPagesTabButton"
                                          Click="LeftSidebarPagesTab_Click"
                                          Padding="12,6"
                                          Background="Transparent"
                                          ToolTipService.ToolTip="Pages">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon x:Name="LeftSidebarPagesTabIcon" Glyph="&#xE8A5;" FontSize="11"/>
                                    <TextBlock x:Name="LeftSidebarPagesTabLabel" Text="Pages" FontSize="12"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="LeftSidebarLayersTabButton"
                                          IsChecked="True"
                                          Click="LeftSidebarLayersTab_Click"
                                          Padding="12,6"
                                          Background="Transparent"
                                          ToolTipService.ToolTip="Layers">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon x:Name="LeftSidebarLayersTabIcon" Glyph="&#xE81E;" FontSize="11"/>
                                    <TextBlock x:Name="LeftSidebarLayersTabLabel" Text="Layers" FontSize="12"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="LeftSidebarPanelsTabButton"
                                          Click="LeftSidebarPanelsTab_Click"
                                          Padding="12,6"
                                          Background="Transparent"
                                          ToolTipService.ToolTip="Panels">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon x:Name="LeftSidebarPanelsTabIcon" Glyph="&#xECA5;" FontSize="11"/>
                                    <TextBlock x:Name="LeftSidebarPanelsTabLabel" Text="Panels" FontSize="12"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="LeftSidebarGuidesTabButton"
                                          Click="LeftSidebarGuidesTab_Click"
                                          Padding="12,6"
                                          Background="Transparent"
                                          ToolTipService.ToolTip="Guides">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon x:Name="LeftSidebarGuidesTabIcon" Glyph="&#xE8FC;" FontSize="11"/>
                                    <TextBlock x:Name="LeftSidebarGuidesTabLabel" Text="Guides" FontSize="12"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- Left Sidebar Tab Content -->
                    <Grid Grid.Row="1">
                        <!-- Pages Tab Content -->
                        <Grid x:Name="LeftSidebarPagesContent" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                    <ListView x:Name="PageListView" Grid.Row="0"
                              Background="Transparent"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              CanDragItems="True"
                              CanReorderItems="True"
                              AllowDrop="True"
                              DragItemsCompleted="PageListView_DragItemsCompleted"
                              ItemClick="PageListView_ItemClick"
                              SelectionChanged="PageListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6">
                                    <Grid.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem x:Name="PageContextDuplicate"
                                                            Text="Duplicate Page"
                                                            Click="DuplicatePageContext_Click"
                                                            Tag="{Binding}"/>
                                            <MenuFlyoutItem Text="Copy selection here"
                                                            Click="CopySelectionToPage_Click"
                                                            Tag="{Binding}"/>
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="52" Height="72"
                                            Background="#1f1f1f"
                                            BorderBrush="#3a3a3a"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" Spacing="2">
                                        <Grid>
                                            <TextBlock x:Name="PageNameTextBlock"
                                                       Text="{Binding Name}"
                                                       Foreground="{Binding TextColor}"
                                                       FontSize="12"
                                                       DoubleTapped="PageName_DoubleTapped"/>
                                            <TextBox x:Name="PageNameTextBox"
                                                     Text="{Binding Name}"
                                                     FontSize="12"
                                                     Padding="4,2"
                                                     Background="#1f1f1f"
                                                     BorderBrush="#3a3a3a"
                                                     BorderThickness="1"
                                                     Visibility="Collapsed"
                                                     LostFocus="PageNameTextBox_LostFocus"
                                                     KeyDown="PageNameTextBox_KeyDown"/>
                                        </Grid>
                                        <TextBlock Text="{Binding SizeText}" Foreground="#888888" FontSize="10"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="84"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- Page Actions -->
                    <Border Grid.Row="1" Background="#252525" Padding="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <Button Click="AddPage_Click" ToolTipService.ToolTip="Add page"
                                    Padding="8,4" Background="#3a3a3a">
                                <FontIcon Glyph="&#xE710;" FontSize="12"/>
                            </Button>
                            <Button x:Name="PageTemplatesButton"
                                    ToolTipService.ToolTip="Page templates"
                                    Padding="8,4"
                                    Background="#3a3a3a">
                                <Button.Flyout>
                                    <MenuFlyout x:Name="PageTemplatesFlyout"
                                                Opening="PageTemplatesFlyout_Opening"/>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8F1;" FontSize="12"/>
                            </Button>
                            <Button Click="DeletePage_Click" ToolTipService.ToolTip="Delete page"
                                    Padding="8,4" Background="#3a3a3a">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                            <Button Click="MovePageUp_Click" ToolTipService.ToolTip="Move up"
                                    Padding="8,4" Background="#3a3a3a">
                                <FontIcon Glyph="&#xE74A;" FontSize="12"/>
                            </Button>
                            <Button Click="MovePageDown_Click" ToolTipService.ToolTip="Move down"
                                    Padding="8,4" Background="#3a3a3a">
                                <FontIcon Glyph="&#xE74B;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Border>
                        </Grid>

                        <!-- Layers/Panels Tab Content (reparented from right sidebar at startup) -->
                    <Grid x:Name="LayersPanelsGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Old inner tab buttons - hidden (tabs now in left sidebar header) -->
                        <Border Grid.Row="0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="LayersTabButton" Visibility="Collapsed"/>
                                <ToggleButton x:Name="PanelsTabButton" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Layer List -->
                        <!-- Tab Contents Container -->
                        <Grid Grid.Row="1">
                            <!-- Layers Tab Content -->
                            <Grid x:Name="LayersTabContent">
                                <ListView x:Name="LayerListView"
                                          Background="Transparent"
                                          AllowDrop="True"
                                          CanDragItems="True"
                                          CanReorderItems="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollMode="Enabled"
                                          SelectionMode="Single"
                                          SelectionChanged="LayerListView_SelectionChanged"
                                          KeyDown="LayerListView_KeyDown"
                                          DragItemsStarting="LayerListView_DragItemsStarting"
                                          DragItemsCompleted="LayerListView_DragItemsCompleted">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,6" Background="Transparent" Margin="{Binding LeftMargin}"
                                          RightTapped="LayerListItem_RightTapped">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Expand/Collapse - Hidden (always expanded now) -->
                                        <Button Grid.Column="0"
                                                Tag="{Binding Id}"
                                                Click="ToggleLayerGroupExpand_Click"
                                                Background="Transparent"
                                                Padding="2"
                                                Margin="0,0,2,0"
                                                Visibility="Collapsed"
                                                ToolTipService.ToolTip="Expand/Collapse">
                                            <FontIcon Glyph="{Binding ExpandGlyph}" FontSize="10" Foreground="#888888"/>
                                        </Button>

                                        <!-- Balloon Indicator -->
                                        <FontIcon Grid.Column="1"
                                                  Glyph="{Binding BalloonGlyph}"
                                                  FontSize="11"
                                                  Foreground="{Binding IndicatorIconForeground}"
                                                  Margin="0,0,4,0"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding BalloonIndicatorVisibility}"/>

                                        <!-- Visibility Toggle -->
                                        <Button Grid.Column="2"
                                                Tag="{Binding Id}"
                                                Click="ToggleLayerVisibility_Click"
                                                Background="Transparent"
                                                Padding="4"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding LayerControlsVisibility}"
                                                ToolTipService.ToolTip="Toggle visibility">
                                            <FontIcon Glyph="{Binding VisibilityGlyph}" FontSize="12" Foreground="#aaaaaa"/>
                                        </Button>

                                        <!-- Lock Toggle -->
                                        <Button Grid.Column="3"
                                                Tag="{Binding Id}"
                                                Click="ToggleLayerLock_Click"
                                                Background="{Binding LockButtonBackground}"
                                                Padding="4"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding LayerControlsVisibility}"
                                                ToolTipService.ToolTip="Toggle lock">
                                            <FontIcon Glyph="{Binding LockGlyph}" FontSize="12" Foreground="{Binding LockIconForeground}"/>
                                        </Button>

                                        <!-- Name (with inline editing) -->
                                        <Grid Grid.Column="4" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="{Binding GroupIconGlyph}" FontSize="11" Foreground="#888888"
                                                      Visibility="{Binding GroupIconVisibility}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       Foreground="{Binding TextColor}"
                                                       FontSize="12"
                                                       FontWeight="{Binding FontWeightValue}"
                                                       DoubleTapped="LayerName_DoubleTapped"
                                                       Tag="{Binding Id}"
                                                       ToolTipService.ToolTip="{Binding HoverToolTip}"/>
                                            <TextBox Grid.Column="1"
                                                     x:Name="LayerNameEditBox"
                                                     Text="{Binding Name}"
                                                     Tag="{Binding Id}"
                                                     Visibility="Collapsed"
                                                     FontSize="12"
                                                     Padding="2"
                                                     MinWidth="80"
                                                     LostFocus="LayerNameEditBox_LostFocus"
                                                     KeyDown="LayerNameEditBox_KeyDown"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="32"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                                </ListView>
                            </Grid>

                            <!-- Panels Tab Content -->
                            <Grid x:Name="PanelsTabContent" Visibility="Collapsed">
                                <ListView x:Name="PanelListView"
                                          Background="Transparent"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollMode="Enabled"
                                          SelectionMode="Extended"
                                          IsItemClickEnabled="True"
                                          ItemClick="PanelListView_ItemClick"
                                          AllowDrop="True"
                                          CanDragItems="True"
                                          CanReorderItems="True"
                                          SelectionChanged="PanelListView_SelectionChanged"
                                          DragItemsStarting="PanelListView_DragItemsStarting"
                                          DragItemsCompleted="PanelListView_DragItemsCompleted"
                                          DragOver="PanelListView_DragOver"
                                          Drop="PanelListView_Drop">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="4,6" Background="Transparent" Margin="{Binding LeftMargin}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Tag="{Binding Id}"
                                                        Click="TogglePanelExpand_Click"
                                                        Background="Transparent"
                                                        Padding="2"
                                                        Margin="0,0,2,0"
                                                        Visibility="Collapsed"
                                                        ToolTipService.ToolTip="Expand/Collapse">
                                                    <FontIcon Glyph="{Binding ExpandGlyph}" FontSize="10" Foreground="#888888"/>
                                                </Button>
                                                <FontIcon Grid.Column="1"
                                                          Glyph="{Binding BalloonGlyph}"
                                                          FontSize="11"
                                                          Foreground="#888888"
                                                          Margin="0,0,4,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding BalloonIndicatorVisibility}"/>
                                                <Button Grid.Column="2"
                                                        Tag="{Binding Id}"
                                                        Click="TogglePanelVisibility_Click"
                                                        Background="Transparent"
                                                        Padding="4"
                                                        Margin="0,0,4,0"
                                                        Visibility="{Binding LayerControlsVisibility}"
                                                        ToolTipService.ToolTip="Toggle visibility">
                                                    <FontIcon Glyph="{Binding VisibilityGlyph}" FontSize="12" Foreground="#aaaaaa"/>
                                                </Button>
                                                <Button Grid.Column="3"
                                                        Tag="{Binding Id}"
                                                        Click="TogglePanelLock_Click"
                                                        Background="{Binding LockButtonBackground}"
                                                        Padding="4"
                                                        Margin="0,0,8,0"
                                                        Visibility="{Binding LayerControlsVisibility}"
                                                        ToolTipService.ToolTip="Toggle lock">
                                                    <FontIcon Glyph="{Binding LockGlyph}" FontSize="12" Foreground="{Binding LockIconForeground}"/>
                                                </Button>
                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding Name}"
                                                           Foreground="{Binding TextColor}"
                                                           FontSize="12"
                                                           FontWeight="{Binding FontWeightValue}"
                                                           VerticalAlignment="Center"
                                                           ToolTipService.ToolTip="{Binding HoverToolTip}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="MinHeight" Value="32"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>
                            </Grid>

                            <!-- Templates Tab Content -->
                            <Grid x:Name="TemplatesTabContent" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Padding="8" Spacing="6">
                                    <TextBox x:Name="PanelTemplateSearchBox"
                                             PlaceholderText="Search templates..."
                                             TextChanged="PanelTemplateSearchBox_TextChanged"/>
                                    <ComboBox x:Name="PanelTemplateCategoryFilterComboBox"
                                              Header="Category"
                                              SelectionChanged="PanelTemplateCategoryFilter_SelectionChanged"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <ListView x:Name="PanelTemplateLibraryListView"
                                              Background="Transparent"
                                              SelectionMode="Single"
                                              ItemTemplate="{StaticResource PanelTemplateItemTemplate}"
                                              SelectionChanged="PanelTemplateLibraryListView_SelectionChanged">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                    </ListView>
                                    <TextBlock x:Name="PanelTemplateLibraryEmptyText"
                                               Text="No panel templates yet."
                                               Foreground="#888888"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Grid>

                            <!-- Page Setup Tab Content -->
                            <!-- Translation Tab Content -->
                            <ScrollViewer x:Name="TranslationTabContent" Visibility="Collapsed">
                                <StackPanel Padding="12" Spacing="12">
                                    <TextBlock x:Name="TranslationWorkflowTitleText"
                                               Text="Translation Workflow"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#ffffff"/>

                                    <!-- Target Languages Section -->
                                    <Border Background="#252525" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="4" Padding="8">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="TranslationTargetLanguagesTitleText"
                                                       Text="Target Languages"
                                                       FontSize="11"
                                                       Foreground="#bcbcbc"/>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="TranslationNewLanguageBox"
                                                         PlaceholderText="e.g., Deutsch"
                                                         TextChanged="TranslationNewLanguageBox_TextChanged"
                                                         KeyDown="TranslationNewLanguageBox_KeyDown"/>
                                                <Button Grid.Column="1"
                                                        x:Name="TranslationAddLanguageButton"
                                                        Content="Add"
                                                        IsEnabled="False"
                                                        Click="TranslationAddLanguageButton_Click"/>
                                            </Grid>
                                            <ListView x:Name="TranslationLanguageListView"
                                                      SelectionMode="Single"
                                                      SelectionChanged="TranslationLanguageListView_SelectionChanged"
                                                      MinHeight="60"
                                                      MaxHeight="120">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="4,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="12"
                                                                       Foreground="#f0f0f0"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding StatusText}"
                                                                       FontSize="10"
                                                                       Foreground="{Binding StatusColor}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="8,0"/>
                                                            <Button Grid.Column="2"
                                                                    Tag="{Binding Name}"
                                                                    Click="TranslationDeleteLanguageButton_Click"
                                                                    ToolTipService.ToolTip="Remove language"
                                                                    Padding="4,2"
                                                                    Background="Transparent"
                                                                    BorderThickness="0">
                                                                <FontIcon Glyph="&#xE74D;" FontSize="10" Foreground="#888888"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <TextBlock x:Name="TranslationNoLanguagesText"
                                                       Text="No target languages. Add one above."
                                                       FontSize="11"
                                                       Foreground="#666666"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Active Language Selector -->
                                    <ComboBox x:Name="TranslationActiveLanguageComboBox"
                                              Header="Active Language"
                                              SelectionChanged="TranslationActiveLanguageComboBox_SelectionChanged"/>

                                    <TextBox x:Name="TranslationSearchBox"
                                             PlaceholderText="Filter balloons..."
                                             TextChanged="TranslationSearchBox_TextChanged"/>
                                    <TextBlock x:Name="TranslationSummaryText"
                                               Text="No balloons"
                                               FontSize="11"
                                               Foreground="#9a9a9a"/>

                                    <ListView x:Name="TranslationBalloonListView"
                                              SelectionMode="Single"
                                              SelectionChanged="TranslationBalloonListView_SelectionChanged"
                                              MinHeight="160"
                                              MaxHeight="280">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="6,4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               FontSize="12"
                                                               Foreground="#f0f0f0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Row="0" Grid.Column="1"
                                                            Padding="6,1"
                                                            CornerRadius="8"
                                                            Background="{Binding StatusBrush}">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#101010"/>
                                                    </Border>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                               Margin="0,3,0,0"
                                                               Text="{Binding Preview}"
                                                               FontSize="10"
                                                               Foreground="#b8b8b8"
                                                               TextWrapping="WrapWholeWords"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="2"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Border x:Name="TranslationResultsPanel"
                                            Background="#252525"
                                            BorderBrush="#3a3a3a"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8"
                                            Visibility="Collapsed">
                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="TranslationResultsTitleText"
                                                           Text="Results"
                                                           FontSize="11"
                                                           Foreground="#bcbcbc"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        x:Name="TranslationResultsDismissButton"
                                                        Click="TranslationResultsDismissButton_Click"
                                                        Padding="4,2"
                                                        Background="Transparent"
                                                        BorderThickness="0">
                                                    <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="#888888"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock x:Name="TranslationResultsSummaryText"
                                                       Text=""
                                                       FontSize="11"
                                                       Foreground="#9a9a9a"
                                                       TextWrapping="WrapWholeWords"/>
                                            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                                <TextBlock x:Name="TranslationResultsDetailsText"
                                                           Text=""
                                                           FontSize="10"
                                                           Foreground="#bbbbbb"
                                                           TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#252525" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="4" Padding="8">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="TranslationSelectedBalloonTitleText"
                                                       Text="Selected Balloon"
                                                       FontSize="11"
                                                       Foreground="#bcbcbc"/>
                                            <TextBlock x:Name="TranslationSourceTextBlock"
                                                       Text="Source: (none)"
                                                       TextWrapping="WrapWholeWords"
                                                       Foreground="#d0d0d0"
                                                       FontSize="11"/>
                                            <TextBox x:Name="TranslationTargetTextBox"
                                                     Header="Target Translation"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     MinHeight="70"/>
                                            <TextBlock x:Name="TranslationDetailStatusText"
                                                       Text=""
                                                       FontSize="11"
                                                       Foreground="#9a9a9a"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                <Button x:Name="TranslationClearButton"
                                                        Content="Clear"
                                                        Click="TranslationClearButton_Click"/>
                                                <Button x:Name="TranslationSaveButton"
                                                        Content="Save"
                                                        Click="TranslationSaveButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Tab-specific Actions -->
                        <Border Grid.Row="2" Background="#252525" Padding="8">
                            <Grid>
                                <!-- Layers Tab Actions -->
                                    <StackPanel x:Name="LayersTabActions" Spacing="8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                        <Button Click="AddLayer_Click" ToolTipService.ToolTip="Add layer"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        </Button>
                                        <Button Click="DeleteLayer_Click" ToolTipService.ToolTip="Delete layer/group"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                        </Button>
                                        <Button Click="MoveLayerUp_Click" ToolTipService.ToolTip="Move up"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE74A;" FontSize="12"/>
                                        </Button>
                                        <Button Click="MoveLayerDown_Click" ToolTipService.ToolTip="Move down"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE74B;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel x:Name="LayerOpacityPanel" Spacing="4" Margin="4,4,4,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Opacity" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="LayerOpacityValueText" Grid.Column="1" Text="100%" FontSize="11" Foreground="#aaaaaa"/>
                                        </Grid>
                                        <Slider x:Name="LayerOpacitySlider"
                                                Minimum="0" Maximum="100"
                                                StepFrequency="5"
                                                ValueChanged="LayerOpacitySlider_ValueChanged"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Panels Tab Actions -->
                                <StackPanel x:Name="PanelsTabActions" Visibility="Collapsed" Spacing="8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                        <ToggleButton x:Name="PanelDesignModeButton"
                                                      Click="PanelDesignModeButton_Click"
                                                      Padding="12,6"
                                                      ToolTipService.ToolTip="Toggle Panel Layout (P)">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                                                <TextBlock Text="Layout" FontSize="11"/>
                                            </StackPanel>
                                        </ToggleButton>
                                        <Button x:Name="PanelTemplatesWindowButton"
                                                Click="ShowTemplatesWindow_Click"
                                                Padding="12,6"
                                                ToolTipService.ToolTip="Open Templates Window">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8A9;" FontSize="12"/>
                                                <TextBlock Text="Templates" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                        <Button Click="AddPanel_Click" ToolTipService.ToolTip="Add panel"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        </Button>
                                        <Button Click="AutoOrderPanels_Click" ToolTipService.ToolTip="Auto-detect reading order"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE8EF;" FontSize="12"/>
                                        </Button>
                                        <Button Click="DeletePanel_Click" ToolTipService.ToolTip="Delete panel"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                        </Button>
                                        <Button Click="DuplicatePanel_Click" ToolTipService.ToolTip="Duplicate panel"
                                                Padding="8,4" Background="#3a3a3a">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Templates Tab Actions -->
                                <StackPanel x:Name="TemplatesTabActions" Visibility="Collapsed" Spacing="6">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                        <Button x:Name="PanelTemplateApplyButton"
                                                Click="PanelTemplateApplyButton_Click"
                                                ToolTipService.ToolTip="Apply Template"
                                                Padding="8,4"
                                                Background="#3a3a3a">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE8FB;" FontSize="12"/>
                                                <TextBlock x:Name="PanelTemplateApplyButtonText" Text="Apply" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PanelTemplateMergeButton"
                                                Click="PanelTemplateMergeButton_Click"
                                                ToolTipService.ToolTip="Merge Template"
                                                Padding="8,4"
                                                Background="#3a3a3a">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE8B7;" FontSize="12"/>
                                                <TextBlock x:Name="PanelTemplateMergeButtonText" Text="Merge" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PanelTemplateRenameButton"
                                                Click="PanelTemplateRenameButton_Click"
                                                ToolTipService.ToolTip="Edit Template"
                                                Padding="8,4"
                                                Background="#3a3a3a">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE70F;" FontSize="12"/>
                                                <TextBlock x:Name="PanelTemplateRenameButtonText" Text="Edit" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PanelTemplateDeleteButton"
                                                Click="PanelTemplateDeleteButton_Click"
                                                ToolTipService.ToolTip="Delete Template"
                                                Padding="8,4"
                                                Background="#3a3a3a">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                                <TextBlock x:Name="PanelTemplateDeleteButtonText" Text="Delete" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                        <Button x:Name="PanelTemplateImportButton"
                                                Click="PanelTemplateImportButton_Click"
                                                ToolTipService.ToolTip="Import Template"
                                                Padding="8,4"
                                                Background="#3a3a3a">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                                <TextBlock x:Name="PanelTemplateImportButtonText" Text="Import..." FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PanelTemplateExportButton"
                                                Click="PanelTemplateExportButton_Click"
                                                ToolTipService.ToolTip="Export Template"
                                                Padding="8,4"
                                                Background="#3a3a3a">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xEDE1;" FontSize="12"/>
                                                <TextBlock x:Name="PanelTemplateExportButtonText" Text="Export" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Page Setup Tab Actions (empty for now) -->
                                <StackPanel x:Name="PageSetupTabActions" Visibility="Collapsed"/>

                                <!-- Translation Tab Actions -->
                                <StackPanel x:Name="TranslationTabActions" Visibility="Collapsed" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Padding="0,4">
                                    <Button x:Name="ExportTranslationsButton"
                                            Click="ExportTranslationsButton_Click"
                                            ToolTipService.ToolTip="Export translation strings to CSV files"
                                            Padding="12,6" Background="#3a3a3a">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xEDE1;" FontSize="12"/>
                                            <TextBlock x:Name="ExportTranslationsButtonText" Text="Export Strings..." FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ImportTranslationsButton"
                                            Click="ImportTranslationsButton_Click"
                                            ToolTipService.ToolTip="Import translation strings from CSV files"
                                            Padding="12,6" Background="#3a3a3a">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                            <TextBlock x:Name="ImportTranslationsButtonText" Text="Import Strings..." FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                    </Grid>

                    <!-- Guides Tab Content (workspace-level, relocated from balloon detail) -->
                    <ScrollViewer Grid.Row="1" x:Name="LeftSidebarGuidesContent" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                        <StackPanel Padding="12,8" Spacing="12">
                            <!-- Snap to Guides -->
                            <StackPanel Spacing="4">
                                <ToggleSwitch x:Name="SnapToGuidesToggle"
                                              Header="Snap to Guides"
                                              OnContent="On" OffContent="Off"
                                              ToolTipService.ToolTip="Snap selected objects to page guides, panel boundaries, and alignment targets."
                                              Toggled="SnapToGuidesToggle_Toggled"/>
                                <ToggleSwitch x:Name="LockGuidesToggle"
                                              Header="Lock Guides"
                                              OnContent="Locked" OffContent="Unlocked"
                                              ToolTipService.ToolTip="Prevent adding, moving, or deleting guides until unlocked."
                                              Toggled="LockGuidesToggle_Toggled"/>
                            </StackPanel>

                            <!-- Panel Boundaries -->
                            <StackPanel Spacing="4" Visibility="Collapsed">
                                <TextBlock x:Name="PanelBoundariesLabelText" Text="Panel Boundaries" FontSize="11" Foreground="#888888"/>
                                <ComboBox x:Name="PanelBoundaryVisibilityComboBox"
                                          SelectionChanged="PanelBoundaryVisibilityComboBox_SelectionChanged"
                                          ToolTipService.ToolTip="Show panel boundaries to constrain object placement and snap against panel edges."
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Always" Tag="Always"/>
                                    <ComboBoxItem Content="Layout Only" Tag="LayoutOnly"/>
                                    <ComboBoxItem Content="Hover" Tag="Hover"/>
                                    <ComboBoxItem Content="Hidden" Tag="Hidden"/>
                                </ComboBox>
                                <TextBlock x:Name="BoundaryTipText" Text="Tip: use Always while placing balloons for predictable edge snapping."
                                           FontSize="10"
                                           Foreground="#6f8497"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Panel Safe Margins -->
                            <StackPanel Spacing="4" Visibility="Collapsed">
                                <TextBlock x:Name="PanelSafeMarginsLabelText" Text="Panel Safe Margins" FontSize="11" Foreground="#888888"/>
                                <ToggleSwitch x:Name="PanelSafeGuidesToggle"
                                              Header="Show Safe Area Guides"
                                              OnContent="On" OffContent="Off"
                                              ToolTipService.ToolTip="Show recommended safe margin inside panels."
                                              Toggled="PanelSafeGuidesToggle_Toggled"/>
                                <TextBlock x:Name="SafeGuidesTipText" Text="Safe guides are dotted teal lines labeled with their margin value."
                                           FontSize="10"
                                           Foreground="#6f8497"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Panel Gutters -->
                            <StackPanel Spacing="4" Visibility="Collapsed">
                                <TextBlock x:Name="PanelGuttersLabelText" Text="Panel Gutters" FontSize="11" Foreground="#888888"/>
                                <ToggleSwitch x:Name="PanelGutterGuidesToggle"
                                              Header="Show Gutter Visuals"
                                              OnContent="On" OffContent="Off"
                                              ToolTipService.ToolTip="Show spacing between panels (gutters)."
                                              Toggled="PanelGutterGuidesToggle_Toggled"/>
                                <TextBlock x:Name="GutterTipText" Text="Gutter width is controlled by panel defaults and per-edge overrides; style controls below affect rendering."
                                           FontSize="10"
                                           Foreground="#6f8497"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Gutter Style -->
                            <StackPanel Spacing="6" Visibility="Collapsed">
                                <TextBlock x:Name="GutterStyleLabelText" Text="Gutter Style" FontSize="11" Foreground="#888888"/>
                                <ToggleSwitch x:Name="PanelGutterFillToggle"
                                              Header="Fill gutter area"
                                              OnContent="On" OffContent="Off"
                                              Toggled="PanelGutterFillToggle_Toggled"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="PanelGutterColorPreview"
                                            Width="24" Height="24"
                                            CornerRadius="4"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            Background="#1E1E1E"/>
                                    <ComboBox x:Name="PanelGutterColorComboBox"
                                              Grid.Column="1"
                                              SelectionChanged="PanelGutterColorComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Dark Gray" Tag="#2C2C2C"/>
                                        <ComboBoxItem Content="Black" Tag="#000000"/>
                                        <ComboBoxItem Content="Gray" Tag="#666666"/>
                                        <ComboBoxItem Content="Light Gray" Tag="#AAAAAA"/>
                                        <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                    </ComboBox>
                                </Grid>
                                <StackPanel Spacing="2">
                                    <TextBlock x:Name="PanelBorderStyleLabelText" Text="Panel Border Style" FontSize="10" Foreground="#666666"/>
                                    <ComboBox x:Name="PanelGutterStrokeStyleComboBox"
                                              SelectionChanged="PanelGutterStrokeStyleComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="None" Tag="None"/>
                                        <ComboBoxItem Content="Solid" Tag="Solid"/>
                                        <ComboBoxItem Content="Dashed" Tag="Dashed"/>
                                        <ComboBoxItem Content="Dotted" Tag="Dotted"/>
                                        <ComboBoxItem Content="Dash-Dot" Tag="DashDot"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Reading Direction -->
                            <StackPanel Spacing="4" Visibility="Collapsed">
                                <TextBlock x:Name="ReadingDirectionLabelText" Text="Reading Direction" FontSize="11" Foreground="#888888"/>
                                <ComboBox x:Name="ReadingDirectionComboBox"
                                          SelectionChanged="ReadingDirectionComboBox_SelectionChanged"
                                          ToolTipService.ToolTip="Direction for reading panel order (left-to-right or right-to-left)."
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Left to Right (Western)" Tag="LeftToRight"/>
                                    <ComboBoxItem Content="Right to Left (Manga)" Tag="RightToLeft"/>
                                    <ComboBoxItem Content="Manual / Custom" Tag="Manual"/>
                                </ComboBox>
                                <TextBlock x:Name="ReadingArrowsTipText" Text="Reading-flow arrows are shown in Panel Layout mode."
                                           FontSize="10"
                                           Foreground="#6f8497"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Add Guide buttons -->
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="AddGuideLabelText" Text="Add Guide" FontSize="11" Foreground="#888888"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="AddHorizontalGuideButton"
                                            Grid.Column="0"
                                            Content="Horizontal"
                                            Click="AddHorizontalGuide_Click"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Ctrl+Alt+H"
                                            Background="#3a3a3a"/>
                                    <Button x:Name="AddVerticalGuideButton"
                                            Grid.Column="2"
                                            Content="Vertical"
                                            Click="AddVerticalGuide_Click"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            ToolTipService.ToolTip="Ctrl+Alt+V"
                                            Background="#3a3a3a"/>
                                </Grid>
                            </StackPanel>

                            <!-- Guide List -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PageGuidesLabelText" Text="Page Guides" FontSize="11" Foreground="#888888"/>
                                    <Button x:Name="ClearGuidesButton"
                                            Grid.Column="1"
                                            Content="Clear All"
                                            Click="ClearGuidesButton_Click"
                                            Padding="8,4"
                                            Background="#3a3a3a"/>
                                </Grid>
                                <TextBlock x:Name="GuideListEmptyText"
                                           Text="No guides on this page."
                                           FontSize="11"
                                           Foreground="#777777"/>
                                <StackPanel x:Name="GuideListPanel" Spacing="4"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Left sidebar Row 2 is unused now (tab-specific actions handled within each tab content) -->
                </Grid>
            </Border>

            <primitives:Thumb x:Name="LeftSidebarSplitter" Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#1a1a1a"
                              DragDelta="LeftSidebarSplitter_DragDelta"/>

            <!-- Canvas Area -->
            <Border Grid.Column="2" Background="#3c3c3c"
                    AllowDrop="True"
                    DragOver="Canvas_DragOver"
                    Drop="Canvas_Drop">
                <Grid>
                    <canvas:CanvasControl
                        x:Name="MainCanvas"
                        Draw="MainCanvas_Draw"
                        CreateResources="MainCanvas_CreateResources"
                        PointerPressed="MainCanvas_PointerPressed"
                        PointerMoved="MainCanvas_PointerMoved"
                        PointerEntered="MainCanvas_PointerEntered"
                        PointerExited="MainCanvas_PointerExited"
                        PointerReleased="MainCanvas_PointerReleased"
                        PointerWheelChanged="MainCanvas_PointerWheelChanged"
                        ManipulationMode="TranslateX,TranslateY,Scale"
                        ManipulationStarted="MainCanvas_ManipulationStarted"
                        ManipulationDelta="MainCanvas_ManipulationDelta"
                        ManipulationCompleted="MainCanvas_ManipulationCompleted"
                        KeyDown="MainCanvas_KeyDown"
                        CharacterReceived="MainCanvas_CharacterReceived"
                        IsTabStop="True"
                        AllowFocusOnInteraction="True"/>
                    <Border x:Name="PanelLayoutToolbar"
                            Background="#2a2a2a"
                            BorderBrush="#3a3a3a"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,12,0,0"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="PanelLayoutTitleText"
                                       Text="Panel Layout"
                                       Foreground="#dddddd"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <!-- Select Tool (default) -->
                            <ToggleButton x:Name="PanelSelectToolButton"
                                          ToolTipService.ToolTip="Select/Move Panels (V)"
                                          Click="PanelSelectTool_Click"
                                          Padding="10,4"
                                          IsChecked="True"
                                          CornerRadius="4">
                                <FontIcon Glyph="&#xEF20;" FontSize="14"/>
                            </ToggleButton>
                            <Border Width="1" Background="#3a3a3a" Margin="2,0"/>
                            <!-- Draw Tools -->
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <ToggleButton x:Name="PanelRectToolButton"
                                              ToolTipService.ToolTip="Draw Rectangle Panel"
                                              Click="PanelShapeTool_Click"
                                              Tag="Rectangle"
                                              Padding="10,4"
                                              CornerRadius="4,0,0,4">
                                    <FontIcon Glyph="&#xE739;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="PanelRoundedRectToolButton"
                                              ToolTipService.ToolTip="Draw Rounded Rectangle Panel"
                                              Click="PanelShapeTool_Click"
                                              Tag="RoundedRect"
                                              Padding="10,4"
                                              CornerRadius="0">
                                    <PathIcon Data="M2,3 L12,3 C12.55,3 13,3.45 13,4 L13,10 C13,10.55 12.55,11 12,11 L2,11 C1.45,11 1,10.55 1,10 L1,4 C1,3.45 1.45,3 2,3 Z"
                                              Width="14"
                                              Height="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="PanelEllipseToolButton"
                                              ToolTipService.ToolTip="Draw Ellipse Panel"
                                              Click="PanelShapeTool_Click"
                                              Tag="Ellipse"
                                              Padding="10,4"
                                              CornerRadius="0">
                                    <FontIcon Glyph="&#xEA3A;" FontSize="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="PanelPolygonToolButton"
                                              ToolTipService.ToolTip="Draw Polygon Panel"
                                              Click="PanelShapeTool_Click"
                                              Tag="Polygon"
                                              Padding="10,4"
                                              CornerRadius="0">
                                    <PathIcon Data="M7,1 L13,4 L13,10 L7,13 L1,10 L1,4 Z"
                                              Width="14"
                                              Height="14"/>
                                </ToggleButton>
                                <ToggleButton x:Name="PanelFreeformToolButton"
                                              ToolTipService.ToolTip="Draw Freeform Panel"
                                              Click="PanelShapeTool_Click"
                                              Tag="Freeform"
                                              Padding="10,4"
                                              CornerRadius="0,4,4,0">
                                    <FontIcon Glyph="&#xE8F0;" FontSize="14"/>
                                </ToggleButton>
                            </StackPanel>
                            <TextBlock x:Name="PanelToolHintText"
                                       Text="Click to select panels"
                                       Foreground="#888888"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Border Width="1" Background="#3a3a3a" Margin="4,0"/>
                            <Button x:Name="PanelArrangeButton"
                                    Padding="10,4"
                                    CornerRadius="4"
                                    ToolTipService.ToolTip="Arrange Panels">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE8CB;" FontSize="12"/>
                                    <TextBlock x:Name="PanelArrangeLabel"
                                               Text="Arrange"
                                               Foreground="#dddddd"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutSubItem Text="Align">
                                            <MenuFlyoutItem Text="Left" Click="PanelAlignLeft_Click"/>
                                            <MenuFlyoutItem Text="Center" Click="PanelAlignCenter_Click"/>
                                            <MenuFlyoutItem Text="Right" Click="PanelAlignRight_Click"/>
                                            <MenuFlyoutSeparator/>
                                            <MenuFlyoutItem Text="Top" Click="PanelAlignTop_Click"/>
                                            <MenuFlyoutItem Text="Middle" Click="PanelAlignMiddle_Click"/>
                                            <MenuFlyoutItem Text="Bottom" Click="PanelAlignBottom_Click"/>
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSubItem Text="Distribute">
                                            <MenuFlyoutItem Text="Horizontally" Click="PanelDistributeHorizontally_Click"/>
                                            <MenuFlyoutItem Text="Vertically" Click="PanelDistributeVertically_Click"/>
                                        </MenuFlyoutSubItem>
                                        <MenuFlyoutSubItem Text="Match Size">
                                            <MenuFlyoutItem Text="Width" Click="PanelMatchWidth_Click"/>
                                            <MenuFlyoutItem Text="Height" Click="PanelMatchHeight_Click"/>
                                            <MenuFlyoutItem Text="Width &amp; Height" Click="PanelMatchSize_Click"/>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Border Width="1" Background="#3a3a3a" Margin="4,0"/>
                            <Button x:Name="ExitPanelLayoutButton"
                                    Click="ExitPanelLayout_Click"
                                    ToolTipService.ToolTip="Exit Panel Layout Mode (P)"
                                    Padding="12,4"
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8BB;" FontSize="12"/>
                                    <TextBlock x:Name="PanelExitLabel" Text="Exit" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <primitives:Thumb x:Name="RightSidebarSplitter" Grid.Column="3"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="#1a1a1a"
                              DragDelta="RightSidebarSplitter_DragDelta"/>

            <!-- Right Sidebar with Layers and Properties -->
            <Border x:Name="RightSidebarBorder" Grid.Column="4" Background="#2d2d2d"
                    BorderBrush="#1a1a1a" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="PropertiesRow" Height="*" MinHeight="160"/>
                        <RowDefinition x:Name="RightSidebarSplitterRow" Height="0"/>
                        <RowDefinition x:Name="LayersRow" Height="0"/>
                    </Grid.RowDefinitions>


                    <!-- Properties Panel - Uses Grid for fixed header/tabs with scrolling content -->
                    <Grid Grid.Row="0" x:Name="PropertiesScrollViewer">
                        <!-- All property panels overlap in same cell - only one visible at a time -->
                        <Grid x:Name="PropertiesPanel"
                              Visibility="Collapsed"
                              HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Balloon Detail Header -->
                            <Border Grid.Row="0" Background="#252525" Padding="12,8">
                                <TextBlock x:Name="BalloonDetailHeaderText" Text="Balloon Detail" FontWeight="SemiBold" FontSize="13" Foreground="#ffffff"/>
                            </Border>
                            <!-- Properties Tabs Header -->
                            <Border x:Name="PropertiesTabsHeaderBorder"
                                    Grid.Row="1"
                                    Background="#1f1f1f"
                                    Padding="4,4"
                                    SizeChanged="PropertiesTabsHeaderBorder_SizeChanged">
                                <StackPanel x:Name="PropertiesTabsHeaderStackPanel" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                                    <ToggleButton x:Name="PropShapeTabButton"
                                                  Click="PropShapeTabButton_Click" Padding="10,5" Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon x:Name="PropShapeTabIcon" Glyph="&#xE90A;" FontSize="11"/>
                                            <TextBlock x:Name="PropShapeTabLabel" Text="Balloon" FontSize="11"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="PropTextTabButton" IsChecked="True"
                                                  Click="PropTextTabButton_Click" Padding="10,5" Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon x:Name="PropTextTabIcon" Glyph="&#xE8D2;" FontSize="11"/>
                                            <TextBlock x:Name="PropTextTabLabel" Text="Text" FontSize="11"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="PropTailTabButton"
                                                  Click="PropTailTabButton_Click" Padding="10,5" Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <PathIcon x:Name="PropTailTabIcon" Width="11" Height="11"
                                                      Data="M2,2 H14 V9 H9.5 L5,13 V9 H2 Z"/>
                                            <TextBlock x:Name="PropTailTabLabel" Text="Tail" FontSize="11"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="PropEffectsTabButton"
                                                  Click="PropEffectsTabButton_Click" Padding="10,5" Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon x:Name="PropEffectsTabIcon" Glyph="&#xE7FC;" FontSize="11"/>
                                            <TextBlock x:Name="PropEffectsTabLabel" Text="Effects" FontSize="11"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>
                            </Border>

                            <!-- Shape Tab Content (formerly General) with its own scroll -->
                            <ScrollViewer Grid.Row="2" x:Name="PropShapeTabScrollViewer"
                                          VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" Visibility="Collapsed">
                            <StackPanel x:Name="PropGeneralTabContent" Padding="12,8,12,12" Spacing="12">
                                        <!-- Balloon Shape -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="BalloonShapeLabelText" Text="Shape" FontSize="11" Foreground="#888888"/>
                                    <ComboBox x:Name="ShapeComboBox"
                                              SelectionChanged="ShapeComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Oval" Tag="Oval"/>
                                        <ComboBoxItem Content="Rounded Rectangle" Tag="RoundedRect"/>
                                        <ComboBoxItem Content="Rectangle" Tag="Rectangle"/>
                                        <ComboBoxItem Content="Radio/Electronic" Tag="Radio"/>
                                        <ComboBoxItem Content="Thought Bubble" Tag="Thought"/>
                                        <ComboBoxItem Content="Splat" Tag="Splat"/>
                                        <ComboBoxItem Content="Burst" Tag="Burst"/>
                                        <ComboBoxItem Content="Whisper" Tag="Whisper"/>
                                        <ComboBoxItem Content="Custom (SVG)" Tag="Custom"/>
                                        <ComboBoxItem x:Name="ShapeNoneItem" Content="None (Text Only)" Tag="None"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Shape smoothness -->
                                <StackPanel x:Name="ThoughtSmoothnessPanel" Spacing="4" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ThoughtSmoothnessLabelText" Text="Bubble Size" FontSize="11" Foreground="#888888"/>
                                        <TextBlock x:Name="ThoughtSmoothnessValueText" Grid.Column="1" Text="55%" FontSize="11" Foreground="#aaaaaa"/>
                                    </Grid>
                                    <Slider x:Name="ThoughtSmoothnessSlider"
                                            Minimum="0" Maximum="100"
                                            Value="55"
                                            StepFrequency="1"
                                            ValueChanged="ThoughtSmoothnessSlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Custom Shape -->
                                <StackPanel x:Name="CustomShapePanel" Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="CustomShapeLabelText" Text="Custom Shape" FontSize="11" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="ImportCustomShapeButton"
                                                Content="Import SVG"
                                                Click="ImportCustomShape_Click"/>
                                    </StackPanel>
                                    <TextBlock x:Name="CustomShapeStatusText"
                                               Text="No custom shape loaded"
                                               FontSize="11"
                                               Foreground="#888888"/>
                                </StackPanel>

                                <!-- Position -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="BalloonPositionLabelText" Text="Position" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnDefinitions="*,8,*">
                                        <NumberBox x:Name="BalloonXBox" Header="X" SpinButtonPlacementMode="Hidden"
                                                   ValueChanged="BalloonPositionBox_ValueChanged"/>
                                        <NumberBox x:Name="BalloonYBox" Grid.Column="2" Header="Y" SpinButtonPlacementMode="Hidden"
                                                   ValueChanged="BalloonPositionBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Size -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="BalloonSizeLabelText" Text="Size" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnDefinitions="*,8,*">
                                        <NumberBox x:Name="BalloonWidthBox" Header="Width" SpinButtonPlacementMode="Hidden" Minimum="10"
                                                   ValueChanged="BalloonSizeBox_ValueChanged"/>
                                        <NumberBox x:Name="BalloonHeightBox" Grid.Column="2" Header="Height" SpinButtonPlacementMode="Hidden" Minimum="10"
                                                   ValueChanged="BalloonSizeBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Rotation -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="BalloonRotationLabelText" Text="Rotation" FontSize="11" Foreground="#888888"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Slider x:Name="BalloonRotationSlider"
                                                Minimum="-180" Maximum="180"
                                                ValueChanged="BalloonRotationSlider_ValueChanged"/>
                                        <NumberBox x:Name="BalloonRotationBox" Grid.Column="1"
                                                   Width="70" Minimum="-180" Maximum="180"
                                                   SpinButtonPlacementMode="Hidden"
                                                   ValueChanged="BalloonRotationBox_ValueChanged"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Panel Assignment -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="BalloonPanelLabelText" Text="Panel" FontSize="11" Foreground="#888888"/>
                                    <ComboBox x:Name="BalloonPanelComboBox"
                                              SelectionChanged="BalloonPanelComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="(None)">
                                    </ComboBox>
                                    <ToggleSwitch x:Name="BalloonConstrainToggle"
                                                  Header="Constrain to panel"
                                                  Toggled="BalloonConstrainToggle_Toggled"
                                                  OnContent="On"
                                                  OffContent="Off"/>
                                </StackPanel>

                                <!-- Balloon State -->
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="PropBalloonStateSectionText"
                                               Text="BALLOON STATE"
                                               Style="{StaticResource BalloonDetailSectionHeaderStyle}"/>
                                    <ToggleSwitch x:Name="BalloonVisibilityToggle"
                                                  Header="Visible"
                                                  Toggled="BalloonVisibilityToggle_Toggled"/>
                                    <ToggleSwitch x:Name="BalloonLockToggle"
                                                  Header="Locked"
                                                  Toggled="BalloonLockToggle_Toggled"/>
                                </StackPanel>

                                <!-- Fill Color -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="FillColorLabelText" Text="Fill Color" FontSize="11" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border x:Name="FillColorPreview"
                                                Width="24" Height="24"
                                                CornerRadius="4"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                Background="White"/>
                                        <ComboBox x:Name="FillColorComboBox"
                                                  SelectionChanged="FillColorComboBox_SelectionChanged"
                                                  Width="120">
                                            <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                            <ComboBoxItem Content="Black" Tag="#000000"/>
                                            <ComboBoxItem Content="Light Gray" Tag="#EEEEEE"/>
                                            <ComboBoxItem Content="Yellow" Tag="#FFFF00"/>
                                            <ComboBoxItem Content="Light Yellow" Tag="#FFFFC0"/>
                                            <ComboBoxItem Content="Red" Tag="#FF0000"/>
                                            <ComboBoxItem Content="Light Red" Tag="#FFE0E0"/>
                                            <ComboBoxItem Content="Blue" Tag="#0066FF"/>
                                            <ComboBoxItem Content="Light Blue" Tag="#E0F0FF"/>
                                            <ComboBoxItem Content="Green" Tag="#00CC00"/>
                                            <ComboBoxItem Content="Light Green" Tag="#E0FFE0"/>
                                            <ComboBoxItem Content="Orange" Tag="#FF8800"/>
                                            <ComboBoxItem Content="Purple" Tag="#9933CC"/>
                                            <ComboBoxItem Content="Pink" Tag="#FF66CC"/>
                                            <ComboBoxItem Content="Custom..." Tag="CUSTOM"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Stroke Color -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="StrokeColorLabelText" Text="Stroke Color" FontSize="11" Foreground="#888888"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border x:Name="StrokeColorPreview"
                                                Width="24" Height="24"
                                                CornerRadius="4"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                Background="Black"/>
                                        <ComboBox x:Name="StrokeColorComboBox"
                                                  SelectionChanged="StrokeColorComboBox_SelectionChanged"
                                                  Width="120">
                                            <ComboBoxItem Content="Black" Tag="#000000"/>
                                            <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                            <ComboBoxItem Content="Dark Gray" Tag="#444444"/>
                                            <ComboBoxItem Content="Light Gray" Tag="#AAAAAA"/>
                                            <ComboBoxItem Content="Red" Tag="#CC0000"/>
                                            <ComboBoxItem Content="Blue" Tag="#0066CC"/>
                                            <ComboBoxItem Content="Green" Tag="#008800"/>
                                            <ComboBoxItem Content="Yellow" Tag="#FFCC00"/>
                                            <ComboBoxItem Content="Orange" Tag="#FF6600"/>
                                            <ComboBoxItem Content="Purple" Tag="#6633CC"/>
                                            <ComboBoxItem Content="Brown" Tag="#663300"/>
                                            <ComboBoxItem Content="Custom..." Tag="CUSTOM"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Stroke Width -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="StrokeWidthLabelText" Text="Stroke Width" FontSize="11" Foreground="#888888"/>
                                    <Slider x:Name="StrokeWidthSlider"
                                            Minimum="1" Maximum="8"
                                            Value="2"
                                            StepFrequency="0.5"
                                            ValueChanged="StrokeWidthSlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Balloon Opacity -->
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="BalloonOpacityLabelText" Text="Opacity" FontSize="11" Foreground="#888888"/>
                                        <TextBlock x:Name="BalloonOpacityValueText" Grid.Column="1" Text="100%" FontSize="11" Foreground="#aaaaaa"/>
                                    </Grid>
                                    <Slider x:Name="BalloonOpacitySlider"
                                            Minimum="0" Maximum="100"
                                            StepFrequency="5"
                                            ValueChanged="BalloonOpacitySlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Corner Radius -->
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="CornerRadiusLabelText" Text="Corner Radius" FontSize="11" Foreground="#888888"/>
                                    <Slider x:Name="CornerRadiusSlider"
                                            Minimum="0" Maximum="80"
                                            StepFrequency="1"
                                            ValueChanged="CornerRadiusSlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Rotation -->
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="RotationLabelText2" Text="Rotation" FontSize="11" Foreground="#888888"/>
                                        <TextBlock x:Name="RotationValueText" Grid.Column="1" Text="0°" FontSize="11" Foreground="#aaaaaa"/>
                                    </Grid>
                                    <Slider x:Name="RotationSlider"
                                            Minimum="-180" Maximum="180"
                                            Value="0"
                                            StepFrequency="1"
                                            ValueChanged="RotationSlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Padding (Individual) -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="PaddingAdvancedLabelText" Text="Padding (Advanced)" FontSize="11" Foreground="#888888"/>
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="PaddingLeftLabelText" Text="Left" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="PaddingLeftBox"
                                                           Minimum="0" Maximum="200"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="1"
                                                           ValueChanged="PaddingLeftBox_ValueChanged"
                                                           KeyDown="NumberBox_KeyDown"
                                                           Width="80"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="PaddingRightLabelText" Text="Right" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="PaddingRightBox"
                                                           Minimum="0" Maximum="200"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="1"
                                                           ValueChanged="PaddingRightBox_ValueChanged"
                                                           KeyDown="NumberBox_KeyDown"
                                                           Width="80"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="PaddingTopLabelText" Text="Top" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="PaddingTopBox"
                                                           Minimum="0" Maximum="200"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="1"
                                                           ValueChanged="PaddingTopBox_ValueChanged"
                                                           KeyDown="NumberBox_KeyDown"
                                                           Width="80"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="PaddingBottomLabelText" Text="Bottom" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="PaddingBottomBox"
                                                           Minimum="0" Maximum="200"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="1"
                                                           ValueChanged="PaddingBottomBox_ValueChanged"
                                                           KeyDown="NumberBox_KeyDown"
                                                           Width="80"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Size Limits -->
                                <StackPanel Spacing="4" Visibility="Collapsed">
                                    <TextBlock x:Name="SizeLimitsLabelText" Text="Size Limits" FontSize="11" Foreground="#888888"/>
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="MinWidthLabelText" Text="Min W" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="MinWidthBox"
                                                           Minimum="0" Maximum="2000"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="5"
                                                           ValueChanged="MinWidthBox_ValueChanged"
                                                           Width="80"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="MinHeightLabelText" Text="Min H" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="MinHeightBox"
                                                           Minimum="0" Maximum="2000"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="5"
                                                           ValueChanged="MinHeightBox_ValueChanged"
                                                           Width="80"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="MaxWidthLabelText" Text="Max W" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="MaxWidthBox"
                                                           Minimum="0" Maximum="2000"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="5"
                                                           ValueChanged="MaxWidthBox_ValueChanged"
                                                           Width="80"/>
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="MaxHeightLabelText" Text="Max H" FontSize="10" Foreground="#aaaaaa"/>
                                                <NumberBox x:Name="MaxHeightBox"
                                                           Minimum="0" Maximum="2000"
                                                           SpinButtonPlacementMode="Hidden"
                                                           SmallChange="5"
                                                           ValueChanged="MaxHeightBox_ValueChanged"
                                                           Width="80"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock x:Name="SizeLimitsHintText" Text="Set max to 0 for no limit" FontSize="10" Foreground="#888888"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            </ScrollViewer>

                            <!-- Text Tab Content with its own scroll -->
                            <ScrollViewer Grid.Row="2" x:Name="PropTextTabScrollViewer"
                                          VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                            <StackPanel x:Name="PropTextTabContent" Padding="12,8,12,12" Spacing="8">

                                <!-- Text Input -->
                                <TextBlock x:Name="PropTextSectionText"
                                           Text="Text"
                                           Style="{StaticResource BalloonDetailSectionHeaderStyle}"
                                           Margin="0,0,0,2"/>
                                <TextBox x:Name="BalloonTextEditBox"
                                         PlaceholderText="Enter balloon text..."
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="64"
                                         MaxHeight="140"
                                         TextChanged="BalloonTextEditBox_TextChanged"
                                         GotFocus="BalloonTextEditBox_GotFocus"
                                         LostFocus="BalloonTextEditBox_LostFocus"/>

                                <Border Height="1" Background="#2a2a2a" Margin="0,10,0,6"/>

                                <!-- FONT -->
                                <TextBlock x:Name="PropFontSectionText"
                                           Text="FONT"
                                           Style="{StaticResource BalloonDetailSectionHeaderStyle}"
                                           Margin="0,0,0,4"/>

                                <!-- Font chooser -->
                                <Button x:Name="FontChooserButton"
                                        Click="FontChooserButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,5" Background="#2a2a2a" CornerRadius="4">
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="FontChooserButtonText" Text="Segoe UI" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="FontChooserButtonPreview" Grid.Column="1" Text="AaBbCc" FontSize="13" Foreground="#777777" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Button>
                                <!-- CJK hint hidden by default, shown only when relevant -->
                                <TextBlock x:Name="FontCjkHintText" FontSize="9" Foreground="#666666" TextWrapping="WrapWholeWords"
                                           Text="" Visibility="Collapsed"/>
                                <TextBlock x:Name="FontFamilyLabelText" Text="" Visibility="Collapsed"/>
                                <Button x:Name="ApplyCjkFontRecommendationButton"
                                        Content="Use Recommended CJK Font"
                                        Click="ApplyCjkFontRecommendationButton_Click"
                                        HorizontalAlignment="Left" Padding="8,3" FontSize="11"
                                        Visibility="Collapsed"/>

                                <!-- Size -->
                                <Grid ColumnSpacing="8" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="FontSizeLabelText" Text="Size" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                    <Slider x:Name="FontSizeSlider" Grid.Column="1"
                                            Minimum="8" Maximum="48" Value="14" StepFrequency="1"
                                            ValueChanged="FontSizeSlider_ValueChanged"/>
                                    <TextBlock x:Name="FontSizeValueText" Grid.Column="2" Text="14px" FontSize="11" Foreground="#aaaaaa" MinWidth="32" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>

                                <!-- Toolbar -->
                                <TextBlock x:Name="WeightStyleLabelText" Text="" Visibility="Collapsed"/>
                                <TextBlock x:Name="ScriptLabelText" Text="" Visibility="Collapsed"/>
                                <Border Background="#2a2a2a" CornerRadius="5" Padding="3" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="1">
                                        <Button x:Name="BoldButton" Width="34" Height="30" MinWidth="0" Padding="0"
                                                Click="BoldToggleButton_Click" Background="Transparent" CornerRadius="3"
                                                ToolTipService.ToolTip="Bold">
                                            <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                                        </Button>
                                        <Button x:Name="ItalicButton" Width="34" Height="30" MinWidth="0" Padding="0"
                                                Click="ItalicToggleButton_Click" Background="Transparent" CornerRadius="3"
                                                ToolTipService.ToolTip="Italic">
                                            <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                                        </Button>
                                        <Button x:Name="UnderlineButton" Width="34" Height="30" MinWidth="0" Padding="0"
                                                Click="UnderlineToggleButton_Click" Background="Transparent" CornerRadius="3"
                                                ToolTipService.ToolTip="Underline">
                                            <TextBlock Text="U" TextDecorations="Underline" FontSize="13"/>
                                        </Button>
                                        <Border Width="1" Background="#444444" Margin="4,5"/>
                                        <Button x:Name="SuperscriptButton" Width="34" Height="30" MinWidth="0" Padding="0"
                                                Click="SuperscriptToggleButton_Click" Background="Transparent" CornerRadius="3"
                                                ToolTipService.ToolTip="Superscript">
                                            <TextBlock Text="X²" FontSize="12"/>
                                        </Button>
                                        <Button x:Name="SubscriptButton" Width="34" Height="30" MinWidth="0" Padding="0"
                                                Click="SubscriptToggleButton_Click" Background="Transparent" CornerRadius="3"
                                                ToolTipService.ToolTip="Subscript">
                                            <TextBlock Text="X₂" FontSize="12"/>
                                        </Button>
                                        <Border Width="1" Background="#444444" Margin="4,5"/>
                                        <Button x:Name="AllCapsButton" Height="30" MinWidth="0" Padding="6,0"
                                                Click="AllCapsButton_Click" Background="Transparent" CornerRadius="3"
                                                ToolTipService.ToolTip="ALL CAPS">
                                            <TextBlock Text="AA" FontSize="12" FontWeight="SemiBold"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <ToggleSwitch x:Name="AllCapsToggle" Visibility="Collapsed"
                                              OffContent="" OnContent="" Toggled="AllCapsToggle_Toggled"/>

                                <!-- Color -->
                                <StackPanel Spacing="3" Margin="0,6,0,0">
                                    <TextBlock x:Name="ColorCaseLabelText" Text="Color" FontSize="10" Foreground="#888888"/>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="TextColorPreview" Width="18" Height="18" CornerRadius="3"
                                                BorderBrush="#555555" BorderThickness="1" Background="Black" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="TextColorComboBox" Grid.Column="1"
                                                  SelectionChanged="TextColorComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Black" Tag="#000000"/>
                                            <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                            <ComboBoxItem Content="Gray" Tag="#666666"/>
                                            <ComboBoxItem Content="Red" Tag="#CC0000"/>
                                            <ComboBoxItem Content="Blue" Tag="#0066CC"/>
                                            <ComboBoxItem Content="Green" Tag="#008800"/>
                                            <ComboBoxItem Content="Yellow" Tag="#FFCC00"/>
                                            <ComboBoxItem Content="Orange" Tag="#FF6600"/>
                                            <ComboBoxItem Content="Purple" Tag="#6633CC"/>
                                            <ComboBoxItem Content="Custom..." Tag="CUSTOM"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="#2a2a2a" Margin="0,8,0,6" Visibility="Collapsed"/>

                                <!-- OUTLINE -->
                                <TextBlock x:Name="OutlineLabelText"
                                           Text="Outline"
                                           Style="{StaticResource BalloonDetailSectionHeaderStyle}"
                                           Margin="0,0,0,4"
                                           Visibility="Collapsed"/>

                                <!-- Outline color -->
                                <Grid ColumnSpacing="6" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="OutlineColorPreview" Width="18" Height="18" CornerRadius="3"
                                            BorderBrush="#555555" BorderThickness="1" Background="Black" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="OutlineColorComboBox" Grid.Column="1"
                                              SelectionChanged="OutlineColorComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Black" Tag="#000000"/>
                                        <ComboBoxItem Content="White" Tag="#FFFFFF"/>
                                        <ComboBoxItem Content="Gray" Tag="#666666"/>
                                        <ComboBoxItem Content="Red" Tag="#CC0000"/>
                                        <ComboBoxItem Content="Blue" Tag="#0066CC"/>
                                        <ComboBoxItem Content="Green" Tag="#008800"/>
                                        <ComboBoxItem Content="Yellow" Tag="#FFCC00"/>
                                        <ComboBoxItem Content="Orange" Tag="#FF6600"/>
                                        <ComboBoxItem Content="Purple" Tag="#6633CC"/>
                                        <ComboBoxItem Content="Custom..." Tag="CUSTOM"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Outline thickness as slider -->
                                <Grid ColumnSpacing="8" Margin="0,4,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Thickness" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                    <Slider x:Name="OutlineWidthSlider" Grid.Column="1"
                                            Minimum="0" Maximum="8" Value="0" StepFrequency="0.5"
                                            ValueChanged="OutlineWidthSlider_ValueChanged"/>
                                    <TextBlock x:Name="OutlineWidthValueText" Grid.Column="2" Text="0" FontSize="11" Foreground="#aaaaaa" MinWidth="24" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                                <!-- Hidden controls kept for code compat -->
                                <NumberBox x:Name="OutlineWidthBox" Visibility="Collapsed"
                                           Minimum="0" Maximum="32" SmallChange="0.5"
                                           SpinButtonPlacementMode="Hidden"
                                           ValueChanged="OutlineWidthBox_ValueChanged"/>
                                <ComboBox x:Name="OutlineWidthPresetComboBox" Visibility="Collapsed"
                                          SelectionChanged="OutlineWidthPresetComboBox_SelectionChanged">
                                    <ComboBoxItem Content="None" Tag="0"/>
                                    <ComboBoxItem Content="Thin" Tag="1"/>
                                    <ComboBoxItem Content="Medium" Tag="2"/>
                                    <ComboBoxItem Content="Thick" Tag="3"/>
                                    <ComboBoxItem Content="Heavy" Tag="4"/>
                                </ComboBox>
                                <!-- Stroke 2/3 hidden for simplicity -->
                                <Border x:Name="Outline2ColorPreview" Visibility="Collapsed"/>
                                <ComboBox x:Name="Outline2ColorComboBox" Tag="0" Visibility="Collapsed"
                                          SelectionChanged="AdditionalOutlineColorComboBox_SelectionChanged"/>
                                <NumberBox x:Name="Outline2WidthBox" Tag="0" Visibility="Collapsed"
                                           ValueChanged="AdditionalOutlineWidthBox_ValueChanged"/>
                                <Border x:Name="Outline3ColorPreview" Visibility="Collapsed"/>
                                <ComboBox x:Name="Outline3ColorComboBox" Tag="1" Visibility="Collapsed"
                                          SelectionChanged="AdditionalOutlineColorComboBox_SelectionChanged"/>
                                <NumberBox x:Name="Outline3WidthBox" Tag="1" Visibility="Collapsed"
                                           ValueChanged="AdditionalOutlineWidthBox_ValueChanged"/>

                                <Border Height="1" Background="#2a2a2a" Margin="0,8,0,6" Visibility="Collapsed"/>

                                <!-- ALIGNMENT (moved above Spacing) -->
                                <TextBlock x:Name="PropAlignmentSectionText"
                                           Text="ALIGNMENT"
                                           Style="{StaticResource BalloonDetailSectionHeaderStyle}"
                                           Margin="0,0,0,2"/>

                                <!-- Horizontal Alignment -->
                                <StackPanel Spacing="3">
                                    <TextBlock x:Name="AlignmentHorizontalLabelText" Text="Horizontal" FontSize="10" Foreground="#888888"/>
                                    <ComboBox x:Name="TextAlignmentComboBox"
                                              SelectionChanged="TextAlignmentComboBox_SelectionChanged"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Left" Tag="Left"/>
                                        <ComboBoxItem Content="Center" Tag="Center"/>
                                        <ComboBoxItem Content="Right" Tag="Right"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Fit Mode -->
                                <StackPanel Spacing="3" Margin="0,4,0,0">
                                    <TextBlock x:Name="FitModeLabelText" Text="Fit Mode" FontSize="10" Foreground="#888888"/>
